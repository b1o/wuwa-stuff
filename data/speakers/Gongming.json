{"words":[{"word":"man","count":2},{"word":"stay","count":2},{"word":"promised","count":2},{"word":"kids","count":2},{"word":"comrades","count":1},{"word":"going","count":1},{"word":"anywhere","count":1},{"word":"hey","count":1},{"word":"young","count":1},{"word":"male","count":1},{"word":"female","count":1},{"word":"lady","count":1},{"word":"shiying","count":1},{"word":"must","count":1},{"word":"happy","count":1},{"word":"someone","count":1},{"word":"visit","count":1},{"word":"keep","count":1},{"word":"word","count":1},{"word":"obstruct","count":1},{"word":"anyone","count":1},{"word":"try","count":1},{"word":"breaking","count":1},{"word":"into","count":1},{"word":"standing","count":1},{"word":"old","count":1},{"word":"peace","count":1},{"word":"cause","count":1},{"word":"any","count":1},{"word":"trouble","count":1},{"word":"spend","count":1},{"word":"little","count":1},{"word":"time","count":1},{"word":"always","count":1},{"word":"friends","count":1},{"word":"stick","count":1},{"word":"together","count":1},{"word":"fortunate","count":1},{"word":"chat","count":1},{"word":"ask","count":1}],"lines":[{"text":"All my comrades are here. I'm not going anywhere!","quest_name":"Monuments of Condolence","quest_id":125000110},{"text":"Hey, young {Male=man;Female=lady}! Shiying must be happy to see someone visit him!","quest_name":"Monuments of Condolence","quest_id":125000110},{"text":"No, I have to stay with them. I promised them, so I have to keep my word.","quest_name":"Monuments of Condolence","quest_id":125000110},{"text":"I did NOT obstruct anyone! I didn't even try breaking into it! I was just standing here! You kids... Can't you kids just let this old man have his peace?","quest_name":"Monuments of Condolence","quest_id":125000110},{"text":"I won't cause any trouble. I just want to spend a little more time with them.","quest_name":"Monuments of Condolence","quest_id":125000110},{"text":"We promised we'd always be friends and stick together, but they weren't as fortunate as me. Let me stay here and have a chat with them. Is that too much to ask?","quest_name":"Monuments of Condolence","quest_id":125000110}]}