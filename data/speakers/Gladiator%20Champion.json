{"words":[{"word":"i'll","count":5},{"word":"matches","count":4},{"word":"final","count":3},{"word":"tomorrow","count":3},{"word":"rover","count":3},{"word":"arena","count":3},{"word":"hyenas","count":3},{"word":"first","count":2},{"word":"done","count":2},{"word":"noon","count":2},{"word":"things","count":2},{"word":"seaside","count":2},{"word":"alright","count":2},{"word":"match","count":2},{"word":"become","count":2},{"word":"without","count":2},{"word":"impressive","count":1},{"word":"snagging","count":1},{"word":"ticket","count":1},{"word":"challenge","count":1},{"word":"attempt","count":1},{"word":"indeed","count":1},{"word":"looks","count":1},{"word":"give","count":1},{"word":"away","count":1},{"word":"fear","count":1},{"word":"okay","count":1},{"word":"demonstrate","count":1},{"word":"true","count":1},{"word":"strength","count":1},{"word":"tomorrow's","count":1},{"word":"mentioned","count":1},{"word":"yet","count":1},{"word":"since","count":1},{"word":"participation","count":1},{"word":"variations","count":1},{"word":"rules","count":1},{"word":"compared","count":1},{"word":"regular","count":1},{"word":"familiarize","count":1},{"word":"meet","count":1},{"word":"elevated","count":1},{"word":"platform","count":1},{"word":"camp","count":1},{"word":"fill","count":1},{"word":"made","count":1},{"word":"experience","count":1},{"word":"far","count":1},{"word":"beating","count":1},{"word":"around","count":1},{"word":"bush","count":1},{"word":"keep","count":1},{"word":"running","count":1},{"word":"smoothly","count":1},{"word":"i'd","count":1},{"word":"forfeit","count":1},{"word":"proceed","count":1},{"word":"seamlessly","count":1},{"word":"management","count":1},{"word":"however","count":1},{"word":"threat","count":1},{"word":"control","count":1},{"word":"competitions","count":1},{"word":"assist","count":1},{"word":"resolving","count":1},{"word":"conflicts","count":1},{"word":"distributing","count":1},{"word":"resources","count":1},{"word":"among","count":1},{"word":"factions","count":1},{"word":"call","count":1},{"word":"place","count":1},{"word":"home","count":1},{"word":"understand","count":1},{"word":"besides","count":1},{"word":"two","count":1},{"word":"victories","count":1},{"word":"belt","count":1},{"word":"substantial","count":1},{"word":"rewards","count":1},{"word":"agree","count":1},{"word":"consider","count":1},{"word":"granting","count":1},{"word":"privileges","count":1},{"word":"future","count":1},{"word":"rush","count":1},{"word":"return","count":1},{"word":"gather","count":1},{"word":"opinions","count":1},{"word":"members","count":1},{"word":"choice","count":1},{"word":"evident","count":1},{"word":"take","count":1},{"word":"time","count":1},{"word":"hahaha","count":1},{"word":"curious","count":1},{"word":"formidable","count":1},{"word":"participant","count":1},{"word":"stepping","count":1},{"word":"into","count":1},{"word":"prior","count":1},{"word":"notice","count":1},{"word":"seems","count":1},{"word":"tampered","count":1},{"word":"reports","count":1},{"word":"given","count":1},{"word":"circumstances","count":1},{"word":"appears","count":1},{"word":"showdown","count":1},{"word":"unavoidable","count":1},{"word":"settle","count":1},{"word":"worry","count":1},{"word":"ensure","count":1},{"word":"accept","count":1},{"word":"defeat","count":1},{"word":"any","count":1},{"word":"complaint","count":1},{"word":"hmph","count":1},{"word":"came","count":1},{"word":"hope","count":1},{"word":"disppoint","count":1},{"word":"impossible","count":1},{"word":"lose","count":1},{"word":"shoot","count":1},{"word":"power","count":1},{"word":"money","count":1},{"word":"faction's","count":1},{"word":"status","count":1},{"word":"thrives","count":1},{"word":"thrive","count":1},{"word":"declines","count":1},{"word":"decline","count":1},{"word":"na","count":1},{"word":"ever","count":1},{"word":"trouble","count":1}],"lines":[{"text":"Impressive, snagging a ticket to challenge me on your first attempt. Well done, well done indeed.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Looks like I'll need to give it my all. The final is tomorrow at noon. Don't back away in fear, okay?","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"I'll demonstrate what true strength is.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"By the way, Rover, there are a few things about tomorrow's final that I haven't mentioned yet.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Since it's your first participation, there are some variations in the rules compared to regular matches. You should familiarize yourself with them before the final.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Meet me at the elevated platform at the camp, and I'll fill you in.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Rover, you made it. How's your experience with the Seaside Arena so far?","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Alright, no beating around the bush. To keep the Seaside Arena running smoothly, I'd like you to forfeit the match.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"The matches can proceed seamlessly because of our management.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"However, you've become a threat to our control over the matches.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"The matches aren't just competitions; they assist in resolving conflicts and distributing resources among factions.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"The Hyenas call this place home, so you should understand.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Besides, with two victories under your belt, you should be in for some substantial rewards. If you agree, we'll consider granting The Hyenas more privileges in the future.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"No rush. How about you return and gather opinions from other members? The right choice will become evident.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"You have until tomorrow noon to think it over. Take your time.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Hahaha, I was curious why there's a formidable participant stepping into the Arena without prior notice.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"It seems you've tampered with the reports.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Alright, given the circumstances, it appears that a showdown between us is unavoidable.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"I'll settle things in our match tomorrow. Don't worry; I'll ensure you accept your defeat without any complaint.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Hmph, you came.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Hope you won't disppoint me, Rover!","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"How… IMPOSSIBLE! How could I lose!","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Shoot. What do you want? Power, money, or your faction's status?","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"\"One thrives, all thrive; one declines, all decline.\" The Hyenas is still as naïve as ever.","quest_name":"A True Arena Champion","quest_id":135000005},{"text":"Why go through the trouble?","quest_name":"A True Arena Champion","quest_id":135000005}]}