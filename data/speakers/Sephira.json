{"words":[{"word":"scared","count":1},{"word":"impossible","count":1},{"word":"fight","count":1},{"word":"i've","count":1},{"word":"always","count":1},{"word":"known","count":1},{"word":"every","count":1},{"word":"roya","count":1},{"word":"knows","count":1},{"word":"terrifying","count":1},{"word":"void","count":1},{"word":"storm","count":1},{"word":"better","count":1},{"word":"anyone","count":1},{"word":"hard","count":1},{"word":"dhalifa","count":1},{"word":"spacetrek","count":1},{"word":"collective","count":1},{"word":"fought","count":1},{"word":"greater","count":1},{"word":"good","count":1},{"word":"two","count":1},{"word":"keep","count":1},{"word":"best","count":1},{"word":"friend","count":1},{"word":"safe","count":1},{"word":"truly","count":1},{"word":"sorry","count":1},{"word":"understand","count":1},{"word":"effort","count":1},{"word":"gone","count":1},{"word":"into","count":1},{"word":"done","count":1},{"word":"take","count":1},{"word":"responsibility","count":1},{"word":"impulsive","count":1},{"word":"actions","count":1},{"word":"dhalifa's","count":1},{"word":"asking","count":1},{"word":"yes","count":1},{"word":"please","count":1},{"word":"help","count":1},{"word":"reconstruction","count":1}],"lines":[{"text":"But aren't you scared?! It's an impossible fight! Why does it have to be you?!","quest_name":"Spacetrek Observatory: Platform Phase","quest_id":176000006},{"text":"…I know. I've always known. Every Roya knows how terrifying the Void Storm is. And I know better than anyone how hard Dhalifa and the Spacetrek Collective have fought against it.","quest_name":"Spacetrek Observatory: Platform Phase","quest_id":176000006},{"text":"I know what you're doing is for the greater good, but I'm not like you two. I just want to keep my best friend safe.","quest_name":"Spacetrek Observatory: Platform Phase","quest_id":176000006},{"text":"I truly am sorry. I understand how much effort has gone into this. I know I shouldn't have done it. But—","quest_name":"Spacetrek Observatory: Platform Phase","quest_id":176000006},{"text":"…I don't know. But I should take responsibility for my impulsive actions. And if Dhalifa's asking... then yes. Please, let me help with the reconstruction.","quest_name":"Spacetrek Observatory: Platform Phase","quest_id":176000006}]}