{"words":[{"word":"gold","count":2},{"word":"i'll","count":2},{"word":"captain","count":2},{"word":"'em","count":2},{"word":"alright","count":1},{"word":"yield","count":1},{"word":"expect","count":1},{"word":"flaming","count":1},{"word":"returned","count":1},{"word":"legendary","count":1},{"word":"pirate","count":1},{"word":"die","count":1},{"word":"stand","count":1},{"word":"chance","count":1},{"word":"stop","count":1},{"word":"playing","count":1},{"word":"coy","count":1},{"word":"tale","count":1},{"word":"every","count":1},{"word":"sailor","count":1},{"word":"heard","count":1},{"word":"chose","count":1},{"word":"surrender","count":1},{"word":"love","count":1},{"word":"spill","count":1},{"word":"everything","count":1},{"word":"fool","count":1},{"word":"hear","count":1},{"word":"anyone","count":1},{"word":"dares","count":1},{"word":"regret","count":1},{"word":"give","count":1},{"word":"sleep","count":1},{"word":"wink","count":1},{"word":"plagued","count":1},{"word":"nightmares","count":1},{"word":"menace","count":1},{"word":"besides","count":1},{"word":"captain's","count":1},{"word":"already","count":1},{"word":"key","count":1},{"word":"found","count":1},{"word":"promised","count":1},{"word":"share","count":1},{"word":"loot","count":1},{"word":"soon","count":1},{"word":"swimming","count":1},{"word":"barrels","count":1},{"word":"wine","count":1}],"lines":[{"text":"Alright, we yield.","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Didn't expect you to be <i>the</i> Flaming Returned, the legendary pirate who can't die… We don't stand a chance.","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Stop playing coy! You know what I'm on about! It's a tale every sailor has heard!","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Now you know why we chose to surrender…","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Gold, for the love of gold, don't! I'll spill everything!","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Fool! Didn't you hear the captain? \"If anyone dares to get in our way, make 'em regret it!\"","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"If we don't give 'em what they want, Captain won't sleep a wink. He'll be plagued with nightmares of this menace!","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Besides, Captain's already off with the key we found. He promised to share the loot with us, and soon I'll be swimming in barrels of wine!","quest_name":"Sail Day, Captain!","quest_id":155000000}]}