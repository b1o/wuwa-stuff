{"words":[{"word":"yes","count":5},{"word":"father","count":5},{"word":"sir","count":4},{"word":"dark","count":4},{"word":"gladiator","count":4},{"word":"coach","count":3},{"word":"aulus","count":3},{"word":"septimont","count":3},{"word":"hunt","count":3},{"word":"undying","count":3},{"word":"tide","count":3},{"word":"please","count":3},{"word":"supposed","count":2},{"word":"end","count":2},{"word":"always","count":2},{"word":"time","count":2},{"word":"monsters","count":2},{"word":"lost","count":2},{"word":"save","count":2},{"word":"warrior","count":2},{"word":"verbia","count":2},{"word":"glory","count":2},{"word":"face","count":2},{"word":"mean","count":1},{"word":"sorry","count":1},{"word":"best","count":1},{"word":"true","count":1},{"word":"opponent","count":1},{"word":"day","count":1},{"word":"finish","count":1},{"word":"sparring","count":1},{"word":"home","count":1},{"word":"kill","count":1},{"word":"debut","count":1},{"word":"match","count":1},{"word":"die","count":1},{"word":"retirement","count":1},{"word":"ceremony","count":1},{"word":"ready","count":1},{"word":"came","count":1},{"word":"running","count":1},{"word":"moment","count":1},{"word":"heard","count":1},{"word":"old","count":1},{"word":"tales","count":1},{"word":"wrong","count":1},{"word":"tide's","count":1},{"word":"curse","count":1},{"word":"creatures","count":1},{"word":"keep","count":1},{"word":"coming","count":1},{"word":"getting","count":1},{"word":"believes","count":1},{"word":"honor","count":1},{"word":"phantoms","count":1},{"word":"warriors","count":1},{"word":"chose","count":1},{"word":"become","count":1},{"word":"myth","count":1},{"word":"thirst","count":1},{"word":"redemption","count":1},{"word":"gave","count":1},{"word":"form","count":1},{"word":"monster","count":1},{"word":"guide","count":1},{"word":"must","count":1},{"word":"name","count":1},{"word":"price","count":1},{"word":"witch","count":1},{"word":"matter","count":1},{"word":"i'll","count":1},{"word":"pay","count":1},{"word":"whatever","count":1},{"word":"takes","count":1},{"word":"allow","count":1},{"word":"introduce","count":1},{"word":"apprentice","count":1},{"word":"weakness","count":1},{"word":"led","count":1},{"word":"medulius","count":1},{"word":"dangled","count":1},{"word":"bait","count":1},{"word":"turned","count":1},{"word":"slaughter","count":1},{"word":"into","count":1},{"word":"feast","count":1},{"word":"nobles","count":1},{"word":"drunk","count":1},{"word":"bloodshed","count":1},{"word":"real","count":1},{"word":"fruit","count":1},{"word":"rotten","count":1},{"word":"root","count":1},{"word":"knew","count":1},{"word":"outrun","count":1},{"word":"made","count":1},{"word":"clung","count":1},{"word":"false","count":1},{"word":"hope","count":1},{"word":"afraid","count":1},{"word":"shadow","count":1},{"word":"cast","count":1},{"word":"septimont's","count":1},{"word":"great","count":1},{"word":"makes","count":1},{"word":"cry","count":1},{"word":"chance","count":1},{"word":"deliver","count":1},{"word":"message","count":1},{"word":"current","count":1},{"word":"ephor","count":1},{"word":"fameless","count":1},{"word":"offers","count":1},{"word":"deepest","count":1},{"word":"respect","count":1},{"word":"beyond","count":1},{"word":"gate","count":1},{"word":"fight","count":1},{"word":"spectacle","count":1},{"word":"replay","count":1},{"word":"cruel","count":1},{"word":"farce","count":1},{"word":"heartless","count":1},{"word":"eyes","count":1},{"word":"place","count":1},{"word":"give","count":1},{"word":"final","count":1},{"word":"duel","count":1},{"word":"deserves","count":1},{"word":"thank","count":1},{"word":"truly","count":1}],"lines":[{"text":"Yes, Coach— I mean, Aulus.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I'm sorry, Aulus.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Yes, sir.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Yes, sir.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"No! You were the best coach in all of Septimont!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I didn't...","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"That's not true!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Because my opponent... was you!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"That day wasn't supposed to end like that. We were supposed to finish sparring and go home like always…","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I couldn't kill my own coach in my debut match… and my father shouldn't die at his own retirement ceremony… I... I just couldn't…","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Yes...","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"But I wasn't, Father. I wasn't ready.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I didn't have the time...","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"It's not that. I came running the moment I heard where you were, so I...","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Yes, sir.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Sir Aulus... no, Father. I want to end this hunt.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"The old tales got it wrong. The Dark Tide's curse isn't about undying monsters. It's about us... creatures of the Dark Tide who keep coming back.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I know what you're getting at. No one believes in a Gladiator who's lost their honor. Those Phantoms... they're warriors who chose to become myth.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Their thirst for redemption gave form to the \"undying monster.\"","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"And I have you to guide me.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Father?","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"No...","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Who... are you?","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Why did you... save me?","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I lost.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I couldn't.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Then what should I do... I must... save him...","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"...Name your price, witch.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Doesn't matter. I'll pay. Whatever it takes.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"The Dark Tide.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I'm a Gladiator of Septimont. The Dark Tide doesn't hunt me. I hunt it.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Warrior, please allow me to introduce myself. I am Verbia, an apprentice Gladiator.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"No, it was my weakness that led to all of this.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Medulius dangled \"glory\" like bait. He turned our slaughter into a feast. It's nobles like him, drunk on bloodshed, who are the real undying monsters of Septimont.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I'm the fruit of a rotten root. I always knew I couldn't outrun what made me… But I still clung to false hope, too afraid to face the shadow cast by Septimont's glory.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"What a great time you're in... it makes me want to cry.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Warrior, if you get the chance… please deliver a message to the current Ephor. The fameless Gladiator Verbia offers her deepest respect.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Beyond that gate is my father.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I won't fight him again. Not for spectacle. Not to replay the same cruel farce for heartless eyes. So please, face him in my place. Give him the final duel he deserves.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Thank you... truly.","quest_name":"Flames in the Deep","quest_id":151000002}]}