{"words":[{"word":"new","count":4},{"word":"life","count":3},{"word":"six","count":2},{"word":"device","count":2},{"word":"start","count":2},{"word":"federation","count":2},{"word":"going","count":2},{"word":"wait","count":2},{"word":"scientist","count":1},{"word":"crippled","count":1},{"word":"rid","count":1},{"word":"heliodic","count":1},{"word":"ha","count":1},{"word":"resonance","count":1},{"word":"ability","count":1},{"word":"forced","count":1},{"word":"spend","count":1},{"word":"entire","count":1},{"word":"trapped","count":1},{"word":"heliogyre","count":1},{"word":"call","count":1},{"word":"roya's","count":1},{"word":"highest","count":1},{"word":"honor","count":1},{"word":"ask","count":1},{"word":"wanted","count":1},{"word":"fate","count":1},{"word":"everyone","count":1},{"word":"acts","count":1},{"word":"respect","count":1},{"word":"truly","count":1},{"word":"wants","count":1},{"word":"help","count":1},{"word":"good","count":1},{"word":"lord","count":1},{"word":"outside","count":1},{"word":"tribe","count":1},{"word":"hah","count":1},{"word":"cares","count":1},{"word":"person","count":1},{"word":"promised","count":1},{"word":"placed","count":1},{"word":"near","count":1},{"word":"solistree","count":1},{"word":"wish","count":1},{"word":"true","count":1},{"word":"i'd","count":1},{"word":"finally","count":1},{"word":"escape","count":1},{"word":"frozen","count":1},{"word":"wasteland","count":1},{"word":"saying","count":1},{"word":"dropped","count":1},{"word":"drive","count":1},{"word":"hahaha","count":1},{"word":"orders","count":1},{"word":"clear","count":1},{"word":"anywhere","count":1},{"word":"matter","count":1},{"word":"happens","count":1},{"word":"lahai-roi","count":1},{"word":"cripple","count":1},{"word":"stop","count":1},{"word":"ah","count":1},{"word":"second","count":1},{"word":"sorry","count":1},{"word":"reason","count":1},{"word":"uninvited","count":1},{"word":"guests","count":1},{"word":"threw","count":1},{"word":"whole","count":1},{"word":"operation","count":1},{"word":"begging","count":1},{"word":"leave","count":1},{"word":"i'll","count":1},{"word":"anything","count":1}],"lines":[{"text":"A scientist... crippled... It's you.","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"All I have to do is get rid of you!","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"Heliodic Six. Ha, the Six.","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"Just because of my Resonance Ability would I be forced to spend my entire life trapped in that Heliogyre! They call it a Roya's highest honor, but did they ask if we wanted that fate?!","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"Everyone acts like they respect me, but the only one who truly wants to help me is that good lord from outside the tribe.","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"Hah? What's that? Who cares?!","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"I just know that person promised that if I placed the device near the Solistree, my wish would come true.","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"Then I'd finally escape from this frozen wasteland and go start a new life in the New Federation!","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"You–you're saying that because I dropped that device there, the Drive is going to...","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"Hahaha... No, his orders were clear. You don't go anywhere. After that, no matter what happens to Lahai-Roi, I'm going to the New Federation to start my new life!","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"You're just a cripple. I won't let you stop me now!","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"Ah—wait—wait a second!","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"I'm sorry, but there's a reason for this! Some uninvited guests threw off the whole operation.","quest_name":"Ode to the Second Sunrise","quest_id":936000002},{"text":"No! I'm begging you, don't leave me here! I'll do anything, just tell me what you need!","quest_name":"Ode to the Second Sunrise","quest_id":936000002}]}