{"words":[{"word":"love","count":5},{"word":"offer","count":3},{"word":"ye","count":3},{"word":"ho","count":2},{"word":"words","count":2},{"word":"working","count":2},{"word":"nonsense","count":1},{"word":"astrology","count":1},{"word":"miss","count":1},{"word":"white","count":1},{"word":"hat","count":1},{"word":"asking","count":1},{"word":"fall","count":1},{"word":"somethin'","count":1},{"word":"plain","count":1},{"word":"odd","count":1},{"word":"bleh","count":1},{"word":"great","count":1},{"word":"noble","count":1},{"word":"descendants","count":1},{"word":"reyes","count":1},{"word":"hear","count":1},{"word":"umm","count":1},{"word":"ceaseless","count":1},{"word":"waves","count":1},{"word":"pledge","count":1},{"word":"loyalty","count":1},{"word":"eternity","count":1},{"word":"bah","count":1},{"word":"gettin'","count":1},{"word":"old","count":1},{"word":"dunderheaded","count":1},{"word":"idea","count":1},{"word":"anyway","count":1},{"word":"male","count":1},{"word":"laddie","count":1},{"word":"female","count":1},{"word":"missy","count":1},{"word":"give","count":1},{"word":"aye","count":1},{"word":"sea","count":1},{"word":"pen","count":1},{"word":"paper","count":1},{"word":"enough","count":1},{"word":"move","count":1},{"word":"time","count":1},{"word":"dawdle","count":1}],"lines":[{"text":"What's all this nonsense?","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"Ho, ho. You know your astrology well, Miss White Hat.","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"\"Offer your love...\"","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"So it's asking us to fall in love with somethin'? That's just plain odd!","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"Bleh.","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"O great, noble descendants of Reyes, hear my words! I offer ye me love!","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"Umm... I shall offer ye my love! The ceaseless waves shall be my pledge of loyalty to you for all eternity!","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"Bah, I'm gettin' too old for this! What dunderheaded idea is this, anyway!","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"Go on, {Male=laddie;Female=missy}. You give it a go!","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"Aye, you. Just a few words, for the love of the sea! What, need a pen and paper, do ye?","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"It's working! It's working!","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"That's enough of that! Let's move out! We've got no time to dawdle!","quest_name":"Old Man and the Whale","quest_id":880000038}]}