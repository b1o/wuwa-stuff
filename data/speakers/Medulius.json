{"words":[{"word":"septimont","count":5},{"word":"playername","count":4},{"word":"tide","count":4},{"word":"ever","count":4},{"word":"dark","count":3},{"word":"i'll","count":3},{"word":"hee","count":2},{"word":"arena","count":2},{"word":"oh","count":2},{"word":"duel","count":2},{"word":"seen","count":2},{"word":"glory","count":2},{"word":"lit","count":2},{"word":"septimont's","count":2},{"word":"daughter","count":2},{"word":"student","count":2},{"word":"spear","count":2},{"word":"final","count":2},{"word":"lumenstone","count":2},{"word":"something","count":2},{"word":"day","count":2},{"word":"verbia","count":2},{"word":"match","count":2},{"word":"electrified","count":2},{"word":"remember","count":2},{"word":"senate","count":2},{"word":"girl","count":2},{"word":"prayers","count":2},{"word":"mine","count":1},{"word":"followed","count":1},{"word":"suggestion","count":1},{"word":"time","count":1},{"word":"standing","count":1},{"word":"inside","count":1},{"word":"terrible","count":1},{"word":"misunderstanding","count":1},{"word":"embraced","count":1},{"word":"already","count":1},{"word":"tear","count":1},{"word":"apart","count":1},{"word":"phrolova","count":1},{"word":"hahaha","count":1},{"word":"witch","count":1},{"word":"promised","count":1},{"word":"grandest","count":1},{"word":"lying","count":1},{"word":"bit","count":1},{"word":"strongest","count":1},{"word":"contender","count":1},{"word":"i've","count":1},{"word":"darkest","count":1},{"word":"depth","count":1},{"word":"escape","count":1},{"word":"fighting","count":1},{"word":"always","count":1},{"word":"fate","count":1},{"word":"binds","count":1},{"word":"love","count":1},{"word":"turned","count":1},{"word":"sharpened","count":1},{"word":"blades","count":1},{"word":"marvelous","count":1},{"word":"exactly","count":1},{"word":"lumenstones","count":1},{"word":"remembered","count":1},{"word":"lingered","count":1},{"word":"abyss","count":1},{"word":"witness","count":1},{"word":"greatest","count":1},{"word":"champion","count":1},{"word":"fated","count":1},{"word":"fall","count":1},{"word":"hand","count":1},{"word":"brightest","count":1},{"word":"sharpest","count":1},{"word":"kind","count":1},{"word":"battle","count":1},{"word":"gladiators","count":1},{"word":"born","count":1},{"word":"miss","count":1},{"word":"lenore","count":1},{"word":"warrior","count":1},{"word":"stood","count":1},{"word":"sentinel's","count":1},{"word":"side","count":1},{"word":"give","count":1},{"word":"everything","count":1},{"word":"earn","count":1},{"word":"place","count":1},{"word":"take","count":1},{"word":"words","count":1},{"word":"seriously","count":1},{"word":"fly","count":1},{"word":"swat","count":1},{"word":"whenever","count":1},{"word":"please","count":1},{"word":"waiting","count":1},{"word":"shrine","count":1},{"word":"light","count":1},{"word":"swords","count":1},{"word":"scowls","count":1},{"word":"male","count":1},{"word":"mr","count":1},{"word":"female","count":1},{"word":"ms","count":1},{"word":"choice","count":1},{"word":"brought","count":1},{"word":"stirred","count":1},{"word":"long-lost","count":1},{"word":"memories","count":1},{"word":"came","count":1},{"word":"flooding","count":1},{"word":"ah","count":1},{"word":"forget","count":1},{"word":"legendary","count":1},{"word":"gladiator","count":1},{"word":"aulus","count":1},{"word":"announced","count":1},{"word":"retirement","count":1},{"word":"chose","count":1},{"word":"opponent","count":1},{"word":"finest","count":1},{"word":"trained","count":1},{"word":"meant","count":1},{"word":"gentle","count":1},{"word":"farewell","count":1},{"word":"symbolic","count":1},{"word":"clashed","count":1},{"word":"fire","count":1},{"word":"steel","count":1},{"word":"crowd","count":1},{"word":"leaping","count":1},{"word":"upper","count":1},{"word":"stands","count":1},{"word":"elbowing","count":1},{"word":"front","count":1},{"word":"row","count":1},{"word":"aulus's","count":1},{"word":"missed","count":1},{"word":"face","count":1},{"word":"inches","count":1},{"word":"blood","count":1},{"word":"hit","count":1},{"word":"air","count":1},{"word":"sharp","count":1},{"word":"intoxicating","count":1},{"word":"newborn's","count":1},{"word":"first","count":1},{"word":"inhale","count":1},{"word":"life","count":1},{"word":"history","count":1},{"word":"books","count":1},{"word":"flinched","count":1},{"word":"end","count":1},{"word":"ran","count":1},{"word":"killed","count":1},{"word":"mood","count":1},{"word":"everyone","count":1},{"word":"real","count":1},{"word":"shame","count":1},{"word":"honestly","count":1},{"word":"yes","count":1},{"word":"disappointed","count":1},{"word":"tragedy","count":1},{"word":"triumph","count":1},{"word":"spectators","count":1},{"word":"decide","count":1},{"word":"w-wait","count":1},{"word":"medulius","count":1},{"word":"elder","count":1},{"word":"whatever","count":1},{"word":"must","count":1},{"word":"connections","count":1},{"word":"word","count":1},{"word":"y-you","count":1},{"word":"knew","count":1},{"word":"wish","count":1},{"word":"pulled","count":1},{"word":"devour","count":1},{"word":"worry","count":1},{"word":"perfectly","count":1},{"word":"fine","count":1},{"word":"unconscious","count":1},{"word":"heard","count":1},{"word":"prayed","count":1},{"word":"wondrous","count":1},{"word":"voice","count":1},{"word":"straight","count":1},{"word":"heavens","count":1},{"word":"pierced","count":1},{"word":"engulfed","count":1},{"word":"gave","count":1},{"word":"strength","count":1},{"word":"senator","count":1},{"word":"graced","count":1},{"word":"beautiful","count":1},{"word":"natural","count":1},{"word":"reward","count":1},{"word":"become","count":1},{"word":"understand","count":1},{"word":"fear","count":1},{"word":"taking","count":1},{"word":"leave","count":1},{"word":"i'd","count":1},{"word":"better","count":1},{"word":"eyesore","count":1},{"word":"find","count":1},{"word":"comfortable","count":1},{"word":"spot","count":1},{"word":"watch","count":1},{"word":"future","count":1},{"word":"unravel","count":1},{"word":"hehe","count":1}],"lines":[{"text":"And mine as well. Hee hee...","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"{PlayerName}, I followed your suggestion. This time, I'm standing inside the arena!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Oh, what a terrible misunderstanding. Both of us have been embraced by the Dark Tide, haven't we? We're already one and the same.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Come on, then! Tear each other apart!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Phrolova... hahaha! That witch promised me the grandest duel Septimont has ever seen.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"And she wasn't lying! Not one bit! You're the strongest contender I've ever seen!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Even in the darkest depth of Septimont, they couldn't escape it. Fighting was always their fate.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Glory binds them to the arena. And the love they had for each other turned to sharpened blades... How marvelous!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Exactly.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"The more Lumenstones you lit, the more of myself I remembered. Now I know why I lingered in this abyss.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"This! This right here, is what I want. To witness Septimont's greatest duel again and again!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"A champion fated to fall by the hand of his daughter, his brightest student, his sharpest spear! That's the kind of battle Gladiators were born for!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Oh, Miss Lenore... I was once a warrior, one who stood by the Sentinel's side. Only those who give everything for glory earn a place in Septimont.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Now, now.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"No need to take my words too seriously. Think of me as a fly, one you can swat whenever you please.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I'll be waiting before the shrine. Light the final Lumenstone.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"No need for swords and scowls, {Male=Mr.;Female=Ms.} {PlayerName}. I didn't come by choice. The Lumenstone brought me.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"When you lit it, something stirred in me. All those long-lost memories came flooding back.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Ah, how could I ever forget that day?","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"The day the legendary Gladiator Aulus announced his retirement and chose his final opponent—his own daughter, Verbia, the finest student he'd ever trained.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"It was meant to be a gentle farewell match. Something symbolic. But they clashed like fire and steel. It electrified the crowd, and it electrified me!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I remember leaping from the upper stands and elbowing my way to the front row. I remember Aulus's spear—it missed my face by inches. And then the blood hit the air. So sharp and intoxicating, like a newborn's first inhale of life.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"It could have been a match for the history books! If only Verbia hadn't flinched at the end. She ran. Killed the mood for everyone. A real shame.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Honestly, yes. I <i>am</i> disappointed.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"But tragedy or triumph... that's for the spectators to decide.","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"W-wait! I'm Medulius, an Elder of Septimont's Senate! Whatever you're after, I can get it for you!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"So it is me you're after? Then you must know the connections I have in the Senate. Just say the word and I'll...","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"Y-you knew...?","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"A... wish?","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"No... no!","quest_name":"Flames in the Deep","quest_id":151000002},{"text":"I pulled this girl out before the Tide could devour her. Don't worry, she's perfectly fine. Just unconscious.","quest_name":"Morning Star II","quest_id":189800001},{"text":"Because I heard the prayers, {PlayerName}.","quest_name":"Morning Star II","quest_id":189800001},{"text":"This girl once prayed for me too, did she not? A wondrous voice straight from the heavens! It even pierced through the Dark Tide that had engulfed me and gave me strength.","quest_name":"Morning Star II","quest_id":189800001},{"text":"I am a Senator of Septimont. Having been graced with such beautiful prayers, it's natural that I reward her. Now we're even.","quest_name":"Morning Star II","quest_id":189800001},{"text":"{PlayerName}, the more I become one with the Dark Tide, the more I understand your fear of it. I'll be taking my leave then. I'd better not make myself more of an eyesore to you.","quest_name":"Morning Star II","quest_id":189800001},{"text":"Let's each find a comfortable spot and watch the future of Septimont unravel. Hehe.","quest_name":"Morning Star II","quest_id":189800001}]}