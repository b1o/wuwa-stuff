{"words":[{"word":"any","count":2},{"word":"i've","count":1},{"word":"keeping","count":1},{"word":"close","count":1},{"word":"eye","count":1},{"word":"case","count":1},{"word":"gets","count":1},{"word":"wild","count":1},{"word":"ideas","count":1},{"word":"hurting","count":1},{"word":"anyone","count":1},{"word":"funny","count":1},{"word":"enough","count":1},{"word":"holding","count":1},{"word":"together","count":1},{"word":"really","count":1},{"word":"waiting","count":1},{"word":"starting","count":1},{"word":"lose","count":1},{"word":"grip","count":1},{"word":"offense","count":1},{"word":"i'll","count":1},{"word":"taking","count":1},{"word":"leave","count":1},{"word":"good","count":1},{"word":"luck","count":1},{"word":"fancy","count":1},{"word":"mister","count":1},{"word":"madam","count":1},{"word":"types","count":1},{"word":"ha","count":1},{"word":"toffee-nosed","count":1},{"word":"snobs","count":1},{"word":"try","count":1},{"word":"asking","count":1},{"word":"ahab","count":1},{"word":"knows","count":1},{"word":"everyone","count":1}],"lines":[{"text":"You're back. I've been keeping a close eye on her, just in case she gets any... wild ideas about hurting anyone.","quest_name":"Woman in Mask","quest_id":165000002},{"text":"Funny enough, she's been holding it together. It's like she really has been waiting on you.","quest_name":"Woman in Mask","quest_id":165000002},{"text":"She's starting to lose her grip again. But now that you're back, no offense, but I'll be taking my leave... Good luck.","quest_name":"Woman in Mask","quest_id":165000002},{"text":"Those fancy Mister and Madam types? Ha! You think I know any toffee-nosed snobs like that? You might try asking Ahab, he knows just about everyone!","quest_name":"Woman in Mask","quest_id":165000002}]}