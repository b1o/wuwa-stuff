ord":"language","count":1},{"word":"etiquette","count":1},{"word":"eh","count":1},{"word":"really","count":1},{"word":"next","count":1},{"word":"said","count":1},{"word":"lot","count":1},{"word":"lie","count":1},{"word":"trust","count":1},{"word":"words","count":1},{"word":"bad","count":1},{"word":"guys","count":1},{"word":"talked","count":1},{"word":"knows","count":1},{"word":"reach","count":1},{"word":"seems","count":1},{"word":"trouble","count":1},{"word":"anything","count":1},{"word":"hmm","count":1},{"word":"unusual","count":1},{"word":"pure","count":1},{"word":"rarely","count":1},{"word":"found","count":1},{"word":"rule","count":1},{"word":"possibility","count":1},{"word":"dyed","count":1},{"word":"looking","count":1},{"word":"structure","count":1},{"word":"types","count":1},{"word":"seem","count":1},{"word":"take","count":1},{"word":"iris","count":1},{"word":"example","count":1},{"word":"similarly","count":1},{"word":"oval-shaped","count":1},{"word":"double","count":1},{"word":"since","count":1},{"word":"notched","count":1},{"word":"cliffrecluse","count":1},{"word":"longer","count":1},{"word":"extra","count":1},{"word":"petal","count":1},{"word":"lemongrass","count":1},{"word":"shape","count":1},{"word":"native","count":1},{"word":"though","count":1},{"word":"conical","count":1},{"word":"inflorescence","count":1},{"word":"trumpet-shaped","count":1},{"word":"corolla","count":1},{"word":"almost","count":1},{"word":"forgot","count":1},{"word":"single-petaled","count":1},{"word":"distinct","count":1},{"word":"peduncle","count":1},{"word":"anyway","count":1},{"word":"special","count":1},{"word":"hardly","count":1},{"word":"any","count":1},{"word":"thinking","count":1},{"word":"newly","count":1},{"word":"cultivated","count":1},{"word":"species","count":1},{"word":"veins","count":1},{"word":"somehow","count":1},{"word":"cross-shaped","count":1},{"word":"feel","count":1},{"word":"traces","count":1},{"word":"frequency","count":1},{"word":"fluctuations","count":1},{"word":"sign","count":1},{"word":"overflowing","count":1},{"word":"guess","count":1},{"word":"created","count":1},{"word":"certain","count":1},{"word":"order","count":1},{"word":"figure","count":1},{"word":"soil","count":1},{"word":"exactly","count":1},{"word":"picture","count":1},{"word":"expected","count":1},{"word":"contains","count":1},{"word":"kind","count":1},{"word":"concentration","count":1},{"word":"higher","count":1},{"word":"usual","count":1},{"word":"please","count":1},{"word":"watch","count":1},{"word":"dangerous","count":1},{"word":"run","count":1},{"word":"ran","count":1},{"word":"near","count":1},{"word":"cliff","count":1},{"word":"home","count":1},{"word":"eating","count":1},{"word":"poisonous","count":1},{"word":"mushroom","count":1},{"word":"managed","count":1},{"word":"antidote","count":1},{"word":"time","count":1},{"word":"imagine","count":1},{"word":"happened","count":1},{"word":"erm","count":1},{"word":"probably","count":1},{"word":"ability","count":1},{"word":"something","count":1},{"word":"looks","count":1},{"word":"t-thank","count":1},{"word":"nothing","count":1},{"word":"glad","count":1},{"word":"hi","count":1},{"word":"playername","count":1},{"word":"encore's","count":1},{"word":"blossoms","count":1},{"word":"wait","count":1},{"word":"shy","count":1},{"word":"hope","count":1},{"word":"finish","count":1},{"word":"ying's","count":1},{"word":"mother","count":1},{"word":"wish","count":1},{"word":"true","count":1},{"word":"according","count":1},{"word":"various","count":1},{"word":"kinds","count":1},{"word":"person's","count":1},{"word":"must","count":1},{"word":"people's","count":1},{"word":"ones","count":1},{"word":"waterlamps","count":1},{"word":"emit","count":1},{"word":"glow","count":1},{"word":"night","count":1},{"word":"passersby","count":1},{"word":"use","count":1},{"word":"guide","count":1},{"word":"snowy","count":1},{"word":"weather","count":1},{"word":"seeing","count":1},{"word":"winter","count":1},{"word":"definitely","count":1},{"word":"happy","count":1},{"word":"dewvetchs","count":1},{"word":"due","count":1},{"word":"sweetness","count":1},{"word":"remind","count":1},{"word":"sugary","count":1},{"word":"candies","count":1},{"word":"however","count":1},{"word":"seasons","count":1},{"word":"hard","count":1},{"word":"put","count":1},{"word":"together","count":1},{"word":"alone","count":1},{"word":"forte","count":1},{"word":"artificial","count":1},{"word":"creations","count":1},{"word":"easily","count":1},{"word":"break","count":1},{"word":"without","count":1},{"word":"actual","count":1},{"word":"substance","count":1},{"word":"journey","count":1},{"word":"blooming","count":1},{"word":"withering","count":1},{"word":"recording","count":1},{"word":"moment","count":1},{"word":"along","count":1},{"word":"mean","count":1},{"word":"express","count":1},{"word":"mind","count":1},{"word":"collected","count":1},{"word":"enough","count":1},{"word":"bring","count":1},{"word":"i'll","count":1},{"word":"weave","count":1}],"lines":[{"text":"Hello... Are you lost? Do you need help?","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Oops, sorry! I should've introduced myself first... I know it's a polite thing to do in Huanglong...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"...Starflower? That's what Grandma Lin likes to call me...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Oops, sorry! I should've introduced myself first... I know it's a polite thing to do in Huanglong...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"It is… It is a delight to make your acquaintance. I am Verina. My \"pressure\" to have the opportunity to meet with you today…","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"My apologies. I used to live in the New Federation, so I'm not very familiar with the language here.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"My apologies. I used to live in the New Federation, so I'm not very familiar with the etiquette here.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Eh? Really? But that flower next to you said she likes you a lot...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Plants don't lie. I trust their words, so you can't be bad guys.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Oh, right. Grandma Lin talked about you. I left those flowers so she knows how to reach me.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"What seems to be the trouble? If there's anything I can help you with...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Hmm... It's an unusual flower indeed. Pure black flowers are rarely found in nature. We can't rule out the possibility that it's been dyed.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"When looking at the structure, there are a few types of flowers that seem similar.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Take Iris, for example. Its petals are similarly oval-shaped, but it has double petals.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"It's not Viola, either, since Viola has notched petals.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Then there's also the Cliffrecluse, but this flower has a longer stamen and an extra petal.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Lemongrass is also similar in shape. It's native to the New Federation, and Huanglong people may not be familiar with it.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Though it has a similar stamen length, it has a conical inflorescence with a trumpet-shaped corolla.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Oh, and I almost forgot the Pecok Flower! It's a single-petaled flower with a similar stamen length!","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"But... The Pecok Flower has a distinct peduncle, while this one doesn't.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Anyway, this black flower does look very special. There are hardly any similar plants in nature.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"So, I'm thinking it might be a newly cultivated species.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Also, its veins are somehow cross-shaped... I can feel some faint traces of frequency fluctuations on it too. It's a sign of overflowing Remnant Energy.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"So, my guess is it should be an unique Remnant plant, created by a certain type of Resonance Energy.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"But in order to figure out the right soil for it, or exactly what type of Resonance Energy it is, I need more than just a picture.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"As I expected! This flower is indeed a type of Remnant plant.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"And it contains a very unique kind of Remnant Energy. The concentration is much higher than usual, too.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Oh, please watch out... It's dangerous to run like that...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"I ran into her near a cliff on my way home. She was eating a poisonous mushroom...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"I managed to make her the antidote in time. Imagine what would have happened if I wasn't there...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Erm, I... I could probably make one for you with my Resonance Ability... If you just need something that looks similar...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Come on, Verina, you can do it...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"T-thank you, it's nothing... I'm glad I could help.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Hi, {PlayerName}. Oh, Encore's here, too. How's it been?","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"Are you here to see the new blossoms? You'll have to wait a while. They're still a bit shy.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"The Wreath of Hope...?","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"I see. You want to help finish the story Ying's mother left her and make her wish come true.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"But... I don't know how to make such a wreath either.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"According to the story, this wreath is made of various kinds of flowers, it can reflect a person's thoughts, and it must blossom forever and never wither.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"The flowers that can reflect people's thoughts... The ones that I can think of are Waterlamps—These flowers emit a faint glow at night, and passersby use them to guide their way.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"Or Wintry Bells. Wintry Bells bloom in cold and snowy weather. Seeing them in a cold winter will definitely make you happy.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"It can also be Dewvetchs. Due to their sweetness, they remind people of sugary candies.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"However... these flowers all bloom in different seasons, so it'll be hard to put them together, let alone have them blossom forever and never wither.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"That's a bit different.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"Flowers made with Forte are just artificial creations. They can easily break up without actual substance.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"It's not the same as life. Every life has its own journey, from blooming to withering, recording the feelings of every moment along the way.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"I see what you mean. A wreath made with feelings...","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"With that, you can express yourself.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"Do you mind if I help?","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"Once you've collected enough flowers, bring them to me. I'll help you weave them into a wreath.","quest_name":"Small Wooly, Big Adventures","quest_id":121000036},{"text":"Me... Me too!","quest_name":"Grand Warstorm","quest_id":140000004}]}