tal","count":1},{"word":"oh","count":1},{"word":"almost","count":1},{"word":"forgot","count":1},{"word":"ask","count":1},{"word":"hehe","count":1},{"word":"great","count":1},{"word":"head","count":1},{"word":"position","count":1},{"word":"wait","count":1},{"word":"okay","count":1},{"word":"hold","count":1},{"word":"horses","count":1},{"word":"i've","count":1},{"word":"prep","count":1},{"word":"work","count":1},{"word":"n-not","count":1},{"word":"j-just","count":1},{"word":"recap","count":1},{"word":"hear","count":1},{"word":"late","count":1},{"word":"anyway","count":1},{"word":"find","count":1},{"word":"waiting","count":1}],"lines":[{"text":"Body of perfection, eyes gleaming with wisdom, and a smile bursting with health! Yes, that's me, Abbowser!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"Aha, you have a good taste! In that case, I'll go easy on you later.","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"The audacity! You'll regret underestimating me!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"Guess what? I ate it! Boo! This world is under my control now! Ha, ha, ha!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"Looks like you haven't figured things out yet. Well, well, enjoy your blissful ignorance while you can, 'cause I'm cooking up something big!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"Ugh, you really ticked me off by taking Lady Primus, but since you also dealt with that pesky one trying to take my turf, I'll forgive you!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"Ha, ha, ha, now Level 10 will be mine again soon!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"Hmph, you better start worrying about yourself! As the Big Boss, I'm about to show you what I'm really made of!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"I'm sending my top three elites to deal with you. Each one's got a special surprise for you. Muahaha!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"Alright, I'm off. Come face me, mortal! Oh, no. Almost forgot to ask...","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"Are you having fun?","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"Hehe, great! I'll head back to my position and wait for you!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"What? Just okay?! Just hold your horses. I've still got some more prep work to do!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"N-not having fun???","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"J-just come back later. I need to recap!","quest_name":"Abbowser Quest","quest_id":221800001},{"text":"Did you hear me? Come later... but not too late! Anyway, you have to come find me. I'll be waiting!","quest_name":"Abbowser Quest","quest_id":221800001}]}