{"words":[{"word":"two","count":1},{"word":"days","count":1},{"word":"finals","count":1},{"word":"unfair","count":1},{"word":"former","count":1},{"word":"teammates","count":1},{"word":"fans","count":1},{"word":"hmph","count":1},{"word":"everyone","count":1},{"word":"thinks","count":1},{"word":"real","count":1},{"word":"truth","count":1},{"word":"consider","count":1},{"word":"fact","count":1},{"word":"true","count":1},{"word":"final's","count":1},{"word":"nearly","count":1},{"word":"contender","count":1},{"word":"mya","count":1},{"word":"claim","count":1},{"word":"title","count":1},{"word":"done","count":1},{"word":"far","count":1},{"word":"track","count":1},{"word":"record","count":1},{"word":"shaky","count":1},{"word":"john","count":1},{"word":"ah","count":1},{"word":"mya's","count":1},{"word":"manager","count":1},{"word":"listen","count":1},{"word":"sorts","count":1},{"word":"talk","count":1},{"word":"'round","count":1},{"word":"odds","count":1},{"word":"crazy","count":1},{"word":"past","count":1},{"word":"champions","count":1},{"word":"always","count":1},{"word":"noble","count":1},{"word":"bloods","count":1},{"word":"mention","count":1},{"word":"originally","count":1},{"word":"ragunna","count":1}],"lines":[{"text":"Just two days before the finals, as well! It's unfair to her former teammates and her fans.","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"Hmph, everyone thinks they know the real truth. But consider this, it's a fact I know to be true...","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"What do you think? The final's nearly here. Will Contender Mya claim the title?","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"She's done well so far, but her track record has been shaky...","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"John? Ah, Mya's manager.","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"Listen, she's got all sorts of talk 'round her, and the odds are crazy. But past champions have always been the noble bloods, haven't they?","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"Not to mention, she's originally from Ragunna...","quest_name":"Shadow of Glory","quest_id":125000126}]}