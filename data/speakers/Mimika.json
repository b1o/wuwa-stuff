{"words":[{"word":"lollo","count":12},{"word":"logistics","count":12},{"word":"deliver","count":11},{"word":"order","count":10},{"word":"playername","count":7},{"word":"thank","count":6},{"word":"storm","count":5},{"word":"time","count":5},{"word":"promise","count":5},{"word":"take","count":5},{"word":"sob","count":5},{"word":"really","count":4},{"word":"spears","count":4},{"word":"tang","count":4},{"word":"manliu","count":4},{"word":"mr","count":4},{"word":"gravity","count":4},{"word":"male","count":4},{"word":"female","count":4},{"word":"must","count":4},{"word":"place","count":4},{"word":"please","count":4},{"word":"found","count":4},{"word":"color","count":4},{"word":"sea","count":3},{"word":"catapult","count":3},{"word":"goods","count":3},{"word":"rest","count":3},{"word":"mortefi","count":3},{"word":"sir","count":3},{"word":"miss","count":3},{"word":"course","count":3},{"word":"into","count":3},{"word":"customers","count":3},{"word":"orders","count":3},{"word":"wait","count":3},{"word":"hehe","count":3},{"word":"father","count":3},{"word":"tough","count":2},{"word":"incinero","count":2},{"word":"petals","count":2},{"word":"air","count":2},{"word":"manager","count":2},{"word":"trajectory","count":2},{"word":"flames","count":2},{"word":"land","count":2},{"word":"said","count":2},{"word":"needed","count":2},{"word":"put","count":2},{"word":"end","count":2},{"word":"tacet","count":2},{"word":"mark","count":2},{"word":"core","count":2},{"word":"give","count":2},{"word":"try","count":2},{"word":"inferno","count":2},{"word":"rider","count":2},{"word":"anyone","count":2},{"word":"made","count":2},{"word":"another","count":2},{"word":"slogan","count":2},{"word":"matter","count":2},{"word":"fulfill","count":2},{"word":"job","count":2},{"word":"enough","count":2},{"word":"oh","count":2},{"word":"seriously","count":2},{"word":"always","count":2},{"word":"thought","count":2},{"word":"guy","count":2},{"word":"mean","count":2},{"word":"stop","count":2},{"word":"spread","count":2},{"word":"finally","count":2},{"word":"done","count":2},{"word":"feels","count":2},{"word":"received","count":2},{"word":"delivered","count":2},{"word":"something","count":2},{"word":"yes","count":2},{"word":"told","count":2},{"word":"age","count":2},{"word":"passed","count":2},{"word":"away","count":2},{"word":"daughter","count":2},{"word":"birthday","count":2},{"word":"present","count":2},{"word":"far","count":2},{"word":"girl","count":2},{"word":"highlight","count":2},{"word":"hear","count":2},{"word":"carry","count":1},{"word":"heavy","count":1},{"word":"came","count":1},{"word":"alternative","count":1},{"word":"ground","count":1},{"word":"transport","count":1},{"word":"day","count":1},{"word":"spent","count":1},{"word":"fortune","count":1},{"word":"freight","count":1},{"word":"branch","count":1},{"word":"figured","count":1},{"word":"maximum","count":1},{"word":"power","count":1},{"word":"correct","count":1},{"word":"fly","count":1},{"word":"destination","count":1},{"word":"assured","count":1},{"word":"initiation","count":1},{"word":"explode","count":1},{"word":"ensure","count":1},{"word":"everything","count":1},{"word":"goes","count":1},{"word":"smoothly","count":1},{"word":"calculated","count":1},{"word":"woodrow","count":1},{"word":"confirmed","count":1},{"word":"path","count":1},{"word":"affected","count":1},{"word":"spot","count":1},{"word":"epicenter","count":1},{"word":"launch","count":1},{"word":"likely","count":1},{"word":"thrown","count":1},{"word":"hey","count":1},{"word":"rover","count":1},{"word":"big","count":1},{"word":"building","count":1},{"word":"option","count":1},{"word":"escape","count":1},{"word":"close","count":1},{"word":"fine","count":1},{"word":"saw","count":1},{"word":"transformed","count":1},{"word":"flew","count":1},{"word":"riding","count":1},{"word":"thanks","count":1},{"word":"ask","count":1},{"word":"sending","count":1},{"word":"rejection","count":1},{"word":"handle","count":1},{"word":"uh","count":1},{"word":"food","count":1},{"word":"medicine","count":1},{"word":"warm","count":1},{"word":"clothes","count":1},{"word":"person","count":1},{"word":"whoever","count":1},{"word":"trapped","count":1},{"word":"starving","count":1},{"word":"freezing","count":1},{"word":"ordered","count":1},{"word":"things","count":1},{"word":"blame","count":1},{"word":"game","count":1},{"word":"show","count":1},{"word":"fate","count":1},{"word":"s-sorry","count":1},{"word":"exactly","count":1},{"word":"customer","count":1},{"word":"needs","count":1},{"word":"lie","count":1},{"word":"i'll","count":1},{"word":"full","count":1},{"word":"responsibility","count":1},{"word":"courier","count":1},{"word":"fair","count":1},{"word":"i-i'm","count":1},{"word":"sorry","count":1},{"word":"saved","count":1},{"word":"amazing","count":1},{"word":"old","count":1},{"word":"coasted","count":1},{"word":"company","count":1},{"word":"long","count":1},{"word":"gig","count":1},{"word":"crisis","count":1},{"word":"kind","count":1},{"word":"tied","count":1},{"word":"chance","count":1},{"word":"redeem","count":1},{"word":"help","count":1},{"word":"neutralize","count":1},{"word":"past","count":1},{"word":"mistakes","count":1},{"word":"failed","count":1},{"word":"keep","count":1},{"word":"care","count":1},{"word":"toxic","count":1},{"word":"pollen","count":1},{"word":"safe","count":1},{"word":"able","count":1},{"word":"huge","count":1},{"word":"threat","count":1},{"word":"brand","count":1},{"word":"listen","count":1},{"word":"i've","count":1},{"word":"heard","count":1},{"word":"involved","count":1},{"word":"definitely","count":1},{"word":"shot","count":1},{"word":"defeating","count":1},{"word":"hundred","count":1},{"word":"thousand","count":1},{"word":"credits","count":1},{"word":"many","count":1},{"word":"money","count":1},{"word":"minute","count":1},{"word":"'not","count":1},{"word":"profitable'","count":1},{"word":"headquarters","count":1},{"word":"terrific","count":1},{"word":"someone","count":1},{"word":"aah","count":1},{"word":"drink","count":1},{"word":"welcome","count":1},{"word":"maybe","count":1},{"word":"apologize","count":1},{"word":"delivering","count":1},{"word":"invested","count":1},{"word":"strengthening","count":1},{"word":"signal","count":1},{"word":"anytime","count":1},{"word":"anywhere","count":1},{"word":"absolutely","count":1},{"word":"promises","count":1},{"word":"remember","count":1},{"word":"word","count":1},{"word":"discounts","count":1},{"word":"new","count":1},{"word":"great","count":1},{"word":"good","count":1},{"word":"wrap","count":1},{"word":"honest","count":1},{"word":"publicity","count":1},{"word":"every","count":1},{"word":"changed","count":1},{"word":"mind","count":1},{"word":"package","count":1},{"word":"late","count":1},{"word":"left","count":1},{"word":"midnight","count":1},{"word":"ranger","count":1},{"word":"young","count":1},{"word":"post","count":1},{"word":"body","count":1},{"word":"delivery","count":1},{"word":"injured","count":1},{"word":"battle","count":1},{"word":"td","count":1},{"word":"outbreaks","count":1},{"word":"trying","count":1},{"word":"protect","count":1},{"word":"friends","count":1},{"word":"fell","count":1},{"word":"valley","count":1},{"word":"employee","count":1},{"word":"save","count":1},{"word":"dying","count":1},{"word":"breath","count":1},{"word":"thinking","count":1},{"word":"saying","count":1},{"word":"turn","count":1},{"word":"ten","count":1},{"word":"last","count":1},{"word":"hoped","count":1},{"word":"doll","count":1},{"word":"carried","count":1},{"word":"complicated","count":1},{"word":"address","count":1},{"word":"identity","count":1},{"word":"identifications","count":1},{"word":"however","count":1},{"word":"couriers","count":1},{"word":"kept","count":1},{"word":"asking","count":1},{"word":"investigating","count":1},{"word":"difficulties","count":1},{"word":"already","count":1},{"word":"playing","count":1},{"word":"dolls","count":1},{"word":"th","count":1},{"word":"inspired","count":1},{"word":"wanted","count":1},{"word":"join","count":1},{"word":"stick","count":1},{"word":"motto","count":1},{"word":"next","count":1},{"word":"bigger","count":1},{"word":"colleagues","count":1},{"word":"research","count":1},{"word":"centers","count":1},{"word":"mentioned","count":1},{"word":"find","count":1},{"word":"spear","count":1},{"word":"parts","count":1},{"word":"bring","count":1},{"word":"coordinates","count":1},{"word":"move","count":1},{"word":"exile","count":1},{"word":"thugs","count":1},{"word":"yunni","count":1},{"word":"talked","count":1},{"word":"ugh","count":1},{"word":"despicable","count":1},{"word":"wow","count":1},{"word":"scattered","count":1},{"word":"everywhere","count":1},{"word":"reaching","count":1},{"word":"barrels","count":1},{"word":"deep","count":1},{"word":"expose","count":1},{"word":"toxins","count":1},{"word":"extended","count":1},{"word":"period","count":1},{"word":"strong","count":1},{"word":"people","count":1},{"word":"impacted","count":1},{"word":"immediate","count":1},{"word":"explosion","count":1},{"word":"w-wouldn't","count":1},{"word":"physically","count":1},{"word":"impacting","count":1},{"word":"pleasure","count":1},{"word":"quite","count":1},{"word":"capable","count":1},{"word":"kidding","count":1},{"word":"shy","count":1},{"word":"feel","count":1},{"word":"free","count":1},{"word":"praise","count":1},{"word":"real","count":1},{"word":"sudden","count":1},{"word":"compliment","count":1},{"word":"o-okay","count":1},{"word":"work","count":1},{"word":"hard","count":1},{"word":"modest","count":1},{"word":"using","count":1},{"word":"service","count":1},{"word":"forward","count":1},{"word":"seeing","count":1},{"word":"goodbye","count":1},{"word":"hello","count":1},{"word":"filter","count":1},{"word":"guess","count":1},{"word":"solve","count":1},{"word":"puzzle","count":1},{"word":"weird","count":1},{"word":"geniuses","count":1}],"lines":[{"text":"Thank you!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Right. I think it would be really tough to carry the heavy Spears through the Sea of Incinero Petals.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"That's when I came up with the alternative to ground transport: the air!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Back in the day, my manager Tang Manliu spent a fortune on a freight catapult for our branch. I figured, if we can catapult goods, why not the Spears too?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"If we can catapult the Spears at the maximum power, and correct their trajectory while they fly over the Sea of Flames, they should land right at their destination.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Rest assured. Mr. Mortefi said an initiation is needed for them to explode.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"To ensure everything goes smoothly, Mr. Mortefi has calculated the trajectory, and Mr. Woodrow has confirmed that the path won't be affected by the Gravity Storm.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"All right. The rest is yours, {Male=sir;Female=miss}. This time, we will put an end to it all!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"That spot is like the epicenter of the Gravity Storm. If we just launch the spears right through it... They would likely get thrown off course by the storm.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Hey, Rover, you see that big building? The Tacet Mark core of all these Incinero Petals is right there…","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"I think the only option is to escape from the Gravity Storm and give it a try up close.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"All right. The rest is yours, {Male=sir;Female=miss}. This time, we will put an end to it all!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"{PlayerName}—!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"We're fine! I saw it! You just transformed into that Inferno Rider and flew all the way into the air, riding on that Gravity Storm!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Tang Manliu...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"And it's all thanks to you!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"You didn't ask anyone before sending that rejection, did you?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Of course! No order is too tough for us to handle! \"We Promise, We Deliver!\"","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"But, but...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Uh... it was some food, medicine, and warm clothes for one person...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Think about it! Whoever made the order must be trapped there, starving and freezing. That's why they ordered those things!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"What if they can't just place another order?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"This isn't a blame game. We tell our customers “We Promise, We Deliver.” Is that all just for show?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"There we go, it must be fate! Let me deliver it, please!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"S-sorry!!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"And that's exactly why we're needed!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"That customer must know that only Lollo Logistics can deliver what he needs there.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Just let me go! Please?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"But why?!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"I will go! If I don't, we may as well tell all of our customers that our slogan is a lie.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"That's right! No matter what, we have to fulfill our orders! That's what we do at Lollo Logistics!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Now, just let me take it from here!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"I'll take full responsibility as the courier for this job! Is that fair enough?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Sob sob...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Oh, sob sob... I-I'm sorry, I really am...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Sob, I...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Oh, was it really you who saved {Male=him;Female=her}?! That's... amazing!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Wait, seriously?! I always thought you were just some old guy who coasted through the company long enough to land the manager gig...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"So this crisis... it's kind of tied to Lollo Logistics, isn't it?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"I mean, this could be our chance to redeem ourselves!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"If we can help them neutralize that Tacet Mark core, it could make up for our past mistakes and fulfill the promise we failed to keep!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Come on, let me take care of this!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"If we can't stop the spread of the toxic pollen, no place will be safe. Lollo Logistics won't be able to deliver goods to those who need them!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Isn't this a huge threat to our brand?!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Listen, I've heard about {PlayerName}. If they're involved, then we definitely have a shot at defeating the Inferno Rider!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"That's a hundred thousand Credits! How many orders do I need to deliver to make that much money...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"How could this be...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Wait a minute, now it's not just 'not profitable'! Even the headquarters can't say no to this!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"That's it! We have to take this order now!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Terrific!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Look! Someone is there!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Aah, right here. Drink, please.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Did you place an order with Lollo Logistics?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"You're welcome. Maybe I should apologize... for not delivering your order on time.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Hehe, of course it did! We've invested in strengthening our signal so that anyone can place orders with us anytime, anywhere.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Absolutely! At Lollo Logistics, we always deliver on our promises, no matter what!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Wait, remember to spread the word about Lollo Logistics! We have discounts for new customers, you know!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Great, the order is finally done. It feels good to wrap this job up.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"To be honest, I once thought it was no more than a publicity slogan, too. No one would really take each and every order so seriously, right?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"But I changed my mind when I received a package delivered by Lollo Logistics. It was something my late father left.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Yes. He was a Midnight Ranger. I was told at a young age that he passed away at his post, and that his body was not even found.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"The delivery guy said my father was injured in a battle against the TD Outbreaks. He was trying to protect his friends when he fell into a valley.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"A Lollo Logistics employee found him, but they could not save him.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"They told me that until his dying breath, he didn't stop thinking about me, saying that his daughter was about to turn ten, and he... he couldn't even see her one last time.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"He hoped that Lollo Logistics would deliver the doll he carried with him as a birthday present to his daughter.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Yes, but it was far more complicated. Father passed before he could say the address and identity, and no identifications could be found with him by then.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"However, couriers from Lollo Logistics didn't give up. They kept asking and investigating while they delivered other goods.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Finally, after all those difficulties, they found the girl. That girl was me.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"But by the time I received this present, I was already over the age of playing dolls. It was my 18th birthday.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Lollo Logistics inspired me. I wanted to join and stick to the motto: We Promise, We Deliver!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Hehe, thank you.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"One order done. Next up, we have a bigger order to deliver!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"My colleagues and I will go with you to the research centers Mr. Mortefi mentioned. We'll try to find those spear parts and bring them back.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"I got the coordinates from him. Let's move.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"These are the Exile thugs Yunni talked about, {Male=sir;Female=miss}.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Ugh, how despicable...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"{PlayerName}, we’re here!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Wow... They're scattered everywhere. I can even see some far away.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Reaching the <color=Highlight>barrels</color> deep in the Sea of Flames will expose us to toxins for an extended period. Even strong people like you can be impacted...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"An immediate explosion?! W-wouldn't want that...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"What do you mean by \"physically impacting them\"?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Tang Manliu, {PlayerName} is here!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"I didn't. Please, {PlayerName}, say something!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Thank you. It was my pleasure!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"You hear that? I'm quite capable!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"You must be kidding, aren't you?","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Don't be so shy. Feel free to praise me, {PlayerName}!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"For real? What's with the sudden compliment? It feels so off to hear that from you.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Hehe! I know right?!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"O-Okay...","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Thank you Tang Manliu, and thank you {PlayerName}! I will work hard!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"You are being modest.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Thank you for using our service. \"We Promise, We Deliver!\"","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"We look forward to seeing you again. Goodbye.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Hello! We're back with the <color=Highlight>filter</color>!","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"I can guess it. We'll need to solve another puzzle made by those weird geniuses.","quest_name":"We Promise, We Deliver","quest_id":122000005}]}