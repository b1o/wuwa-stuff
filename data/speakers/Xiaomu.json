{"words":[{"word":"grandpa","count":4},{"word":"take","count":2},{"word":"away","count":2},{"word":"hehe","count":2},{"word":"either","count":2},{"word":"qiu","count":2},{"word":"i-i","count":1},{"word":"melody","count":1},{"word":"going","count":1},{"word":"cheeks","count":1},{"word":"getting","count":1},{"word":"sore","count":1},{"word":"break","count":1},{"word":"little","count":1},{"word":"huh","count":1},{"word":"waiting","count":1},{"word":"ask","count":1},{"word":"means","count":1},{"word":"breath","count":1},{"word":"believe","count":1},{"word":"saying","count":1},{"word":"reason","count":1},{"word":"big","count":1},{"word":"birdie","count":1},{"word":"became","count":1},{"word":"mourning","count":1},{"word":"aix","count":1},{"word":"lost","count":1},{"word":"loved","count":1},{"word":"mrs","count":1},{"word":"mr","count":1},{"word":"passed","count":1},{"word":"longer","count":1},{"word":"made","count":1},{"word":"delicious","count":1},{"word":"rice","count":1},{"word":"cakes","count":1},{"word":"used","count":1},{"word":"taste","count":1},{"word":"salty","count":1},{"word":"bitter","count":1},{"word":"learned","count":1}],"lines":[{"text":"I-I just can't do it, Grandpa. I can't even get a melody going, and my cheeks are getting sore...","quest_name":"Stygian Lacrimosa","quest_id":118000002},{"text":"Can we take a break for just a little... Huh? Are you here for my grandpa?","quest_name":"Stygian Lacrimosa","quest_id":118000002},{"text":"Well, I can't have you waiting on me. Ask away.","quest_name":"Stygian Lacrimosa","quest_id":118000002},{"text":"Hehe. Then that means I can take a breath for a while!","quest_name":"Stygian Lacrimosa","quest_id":118000002},{"text":"See, Grandpa? They don't believe you either!","quest_name":"Stygian Lacrimosa","quest_id":118000002},{"text":"So... you're saying the reason why big \"birdie\" became the Mourning Aix, is because it lost its loved one?","quest_name":"Stygian Lacrimosa","quest_id":118000002},{"text":"Like Mrs. Qiu. After Mr. Qiu passed away, she no longer made delicious rice cakes like she used to. Now they taste either salty or bitter.","quest_name":"Stygian Lacrimosa","quest_id":118000002},{"text":"Hehe. I learned it all from Grandpa!","quest_name":"Stygian Lacrimosa","quest_id":118000002}]}