{"words":[{"word":"time","count":6},{"word":"always","count":4},{"word":"really","count":4},{"word":"i've","count":3},{"word":"already","count":3},{"word":"little","count":3},{"word":"parents","count":3},{"word":"today","count":2},{"word":"sunset","count":2},{"word":"sumika","count":2},{"word":"moment","count":2},{"word":"keeps","count":2},{"word":"old","count":2},{"word":"two","count":2},{"word":"maybe","count":2},{"word":"school","count":2},{"word":"sky","count":2},{"word":"day","count":2},{"word":"never","count":2},{"word":"left","count":2},{"word":"kind","count":2},{"word":"heh","count":2},{"word":"interesting","count":2},{"word":"analogy","count":2},{"word":"spent","count":2},{"word":"i'd","count":2},{"word":"became","count":2},{"word":"things","count":2},{"word":"loop","count":2},{"word":"something","count":1},{"word":"wrong","count":1},{"word":"playername","count":1},{"word":"turn","count":1},{"word":"voice","count":1},{"word":"radio","count":1},{"word":"broken","count":1},{"word":"next","count":1},{"word":"heard","count":1},{"word":"anything","count":1},{"word":"yes","count":1},{"word":"must","count":1},{"word":"exhausted","count":1},{"word":"cafe","count":1},{"word":"nice","count":1},{"word":"weather","count":1},{"word":"rare","count":1},{"word":"probably","count":1},{"word":"capture","count":1},{"word":"ambers","count":1},{"word":"investigate","count":1},{"word":"possibly","count":1},{"word":"cause","count":1},{"word":"unusual","count":1},{"word":"child","count":1},{"word":"signpost","count":1},{"word":"seventh","count":1},{"word":"seen","count":1},{"word":"fall","count":1},{"word":"cashier","count":1},{"word":"wiping","count":1},{"word":"stain","count":1},{"word":"walls","count":1},{"word":"barely","count":1},{"word":"standing","count":1},{"word":"uniform","count":1},{"word":"spotless","count":1},{"word":"vending","count":1},{"word":"machine","count":1},{"word":"due","count":1},{"word":"restocking","count":1},{"word":"soda","count":1},{"word":"bottles","count":1},{"word":"decades","count":1},{"word":"cat","count":1},{"word":"lying","count":1},{"word":"months","count":1},{"word":"longer","count":1},{"word":"known","count":1},{"word":"middle","count":1},{"word":"students","count":1},{"word":"taking","count":1},{"word":"photos","count":1},{"word":"class","count":1},{"word":"torn","count":1},{"word":"apart","count":1},{"word":"resonance","count":1},{"word":"cords","count":1},{"word":"eyes","count":1},{"word":"clouds","count":1},{"word":"birds","count":1},{"word":"rainbows","count":1},{"word":"perfect","count":1},{"word":"single","count":1},{"word":"store","count":1},{"word":"playing","count":1},{"word":"pop","count":1},{"word":"songs","count":1},{"word":"last","count":1},{"word":"century","count":1},{"word":"window","count":1},{"word":"shut","count":1},{"word":"stuck","count":1},{"word":"notch","count":1},{"word":"years","count":1},{"word":"ago","count":1},{"word":"behind","count":1},{"word":"past","count":1},{"word":"starting","count":1},{"word":"forget","count":1},{"word":"life","count":1},{"word":"almost","count":1},{"word":"feels","count":1},{"word":"every","count":1},{"word":"summer","count":1},{"word":"break","count":1},{"word":"cool","count":1},{"word":"fans","count":1},{"word":"watermelons","count":1},{"word":"tv","count":1},{"word":"loved","count":1},{"word":"watching","count":1},{"word":"anime","count":1},{"word":"curious","count":1},{"word":"special","count":1},{"word":"worlds","count":1},{"word":"lost","count":1},{"word":"entire","count":1},{"word":"holiday's","count":1},{"word":"worth","count":1},{"word":"homework","count":1},{"word":"worked","count":1},{"word":"hard","count":1},{"word":"teachers","count":1},{"word":"scold","count":1},{"word":"felt","count":1},{"word":"terrible","count":1},{"word":"long","count":1},{"word":"save","count":1},{"word":"work","count":1},{"word":"second","count":1},{"word":"finish","count":1},{"word":"unanswered","count":1},{"word":"call","count":1},{"word":"busy","count":1},{"word":"whenever","count":1},{"word":"missed","count":1},{"word":"try","count":1},{"word":"calling","count":1},{"word":"answer","count":1},{"word":"resonator","count":1},{"word":"placed","count":1},{"word":"supervision","count":1},{"word":"chances","count":1},{"word":"rarer","count":1},{"word":"people","count":1},{"word":"said","count":1},{"word":"ended","count":1},{"word":"putting","count":1},{"word":"lot","count":1},{"word":"pressure","count":1},{"word":"hometown","count":1},{"word":"resonators","count":1},{"word":"accepted","count":1},{"word":"someone","count":1},{"word":"control","count":1},{"word":"abilities","count":1},{"word":"ticking","count":1},{"word":"bomb","count":1},{"word":"feared","count":1},{"word":"resented","count":1},{"word":"suffer","count":1},{"word":"thought","count":1},{"word":"stayed","count":1},{"word":"away","count":1},{"word":"deal","count":1},{"word":"looks","count":1},{"word":"whispers","count":1},{"word":"close","count":1},{"word":"hate","count":1},{"word":"ordinary","count":1},{"word":"jobs","count":1},{"word":"hardly","count":1},{"word":"together","count":1},{"word":"sometimes","count":1},{"word":"miss","count":1},{"word":"end","count":1},{"word":"vicious","count":1},{"word":"tried","count":1},{"word":"many","count":1},{"word":"times","count":1},{"word":"outcome","count":1},{"word":"appeared","count":1},{"word":"dangerous","count":1},{"word":"place","count":1},{"word":"beneath","count":1},{"word":"lament's","count":1},{"word":"shadow","count":1},{"word":"luck","count":1},{"word":"coincidence","count":1},{"word":"sonoro","count":1},{"word":"fully","count":1},{"word":"sealed","count":1},{"word":"anymore","count":1},{"word":"cracked","count":1},{"word":"open","count":1},{"word":"met","count":1},{"word":"begun","count":1},{"word":"loosen","count":1}],"lines":[{"text":"Is something wrong, {PlayerName}? Why did you turn back?","quest_name":"Flowing Starlight in the Iris","quest_id":165000004},{"text":"A voice from the radio? But isn't it broken?","quest_name":"Flowing Starlight in the Iris","quest_id":165000004},{"text":"You did? I'm right next to you, but... I don't think I heard anything.","quest_name":"Flowing Starlight in the Iris","quest_id":165000004},{"text":"Yes. You must be exhausted. Should we go back to the cafe?","quest_name":"Flowing Starlight in the Iris","quest_id":165000004},{"text":"Nice weather today. Rare to see a sunset like this. If Sumika were here, she'd probably capture this moment in one of her ambers.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"No. To investigate what could possibly cause a sunset so unusual...","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"See that child by the signpost?","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"That's the seventh time I've seen him fall there.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"The cashier keeps wiping a stain that isn't there... The walls are barely standing, but her uniform is spotless... just like it was.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"The vending machine is due for restocking. With soda bottles that are already decades old.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"That cat has been lying there for two months... maybe longer. I've only known it for two.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"Middle school students are still taking photos of the sky after class, one that is now torn apart by Resonance Cords. But in their eyes, it's still clouds. Birds. Rainbows... the perfect sky of that single day.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"The store keeps playing pop songs from the last century. The window that never shut all the way is still stuck at the notch it was left on years ago.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"They've all been left behind in the past.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"As for me... I'm starting to forget what day it is today.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"This kind of life almost feels like...","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"…Heh. Interesting analogy. When I was little, every summer break was spent with cool fans, watermelons, and an old TV. I loved watching anime and was always curious about those... special worlds.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"…Heh. Interesting analogy. When I was little, I once lost an entire holiday's worth of homework I'd worked really hard on. My parents and teachers didn't scold me, but I still felt terrible about it for a long time... Now I always save my work the second I finish it.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"I think it's kind of like... an unanswered call.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"My parents were always busy. Whenever I missed them, I'd try calling... but most of the time, they couldn't answer. Even when they did, we never had much to say.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"After I became a Resonator and was placed under supervision, those chances became even rarer. I think the things people said about me ended up putting a lot of pressure on them, too.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"In my hometown, Resonators aren't really accepted. Someone who can't control their abilities is like a ticking time bomb... feared and resented.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"I didn't want my parents to suffer because of me. So I thought... maybe if I stayed away, they wouldn't have to deal with the looks. Or the whispers.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"I can't say we're very close.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"...It's not that I hate them. Things were just... ordinary. They had their jobs, I had school. We hardly spent time together.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"But... sometimes, I do miss them. Just a little.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"I really... really want to end this vicious loop.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"I've already tried so many times, but the outcome is always the same...","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"So you appeared.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"At a time no one should have. In the most dangerous place. Beneath the Lament's shadow. It wasn't luck or coincidence.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"The Sonoro isn't fully sealed anymore. Sumika cracked it open. And from the moment we met, the loop had already begun to loosen.","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"Why would you...","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044}]}