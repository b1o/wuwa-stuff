{"words":[{"word":"alone","count":2},{"word":"thank","count":1},{"word":"cantarella","count":1},{"word":"everything","count":1},{"word":"done","count":1},{"word":"years","count":1},{"word":"leaving","count":1},{"word":"left","count":1},{"word":"never","count":1},{"word":"bear","count":1},{"word":"heavy","count":1},{"word":"burden","count":1},{"word":"remember","count":1},{"word":"told","count":1},{"word":"trials","count":1},{"word":"said","count":1},{"word":"wanted","count":1},{"word":"leave","count":1},{"word":"place","count":1},{"word":"behind","count":1},{"word":"somewhere","count":1},{"word":"far","count":1},{"word":"away","count":1},{"word":"knew","count":1},{"word":"live","count":1},{"word":"freely","count":1},{"word":"staying","count":1},{"word":"cold","count":1},{"word":"castle","count":1},{"word":"bearing","count":1}],"lines":[{"text":"Thank you, Cantarella, for everything you've done for us for all these years.","quest_name":"A Fleeting Night's Dream","quest_id":880000033},{"text":"Now that we're leaving, you'll be left alone here…","quest_name":"A Fleeting Night's Dream","quest_id":880000033},{"text":"You should never have had to bear such a heavy burden.","quest_name":"A Fleeting Night's Dream","quest_id":880000033},{"text":"I still remember what you told me back then, during the trials. You said you wanted to leave this place behind, go somewhere far away where no one knew you, and live freely...","quest_name":"A Fleeting Night's Dream","quest_id":880000033},{"text":"But now, you're staying in this cold castle, bearing it all alone…","quest_name":"A Fleeting Night's Dream","quest_id":880000033}]}