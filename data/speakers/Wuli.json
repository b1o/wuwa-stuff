{"words":[{"word":"fuling","count":7},{"word":"found","count":2},{"word":"finally","count":2},{"word":"i've","count":2},{"word":"together","count":2},{"word":"end","count":2},{"word":"great","count":1},{"word":"news","count":1},{"word":"slow","count":1},{"word":"illness","count":1},{"word":"pain","count":1},{"word":"love","count":1},{"word":"forever","count":1},{"word":"happy","count":1},{"word":"haha","count":1},{"word":"yes","count":1},{"word":"rover","count":1},{"word":"lady","count":1},{"word":"changli","count":1},{"word":"never","count":1},{"word":"properly","count":1},{"word":"thanked","count":1},{"word":"bringing","count":1},{"word":"hongzhen","count":1},{"word":"heard","count":1},{"word":"attack","count":1},{"word":"fractsidus","count":1},{"word":"mountains","count":1},{"word":"sorry","count":1},{"word":"truth","count":1},{"word":"behind","count":1},{"word":"so-called","count":1},{"word":"secret","count":1},{"word":"immortality","count":1},{"word":"told","count":1},{"word":"everything","count":1},{"word":"gut","count":1},{"word":"feeling","count":1},{"word":"turn","count":1},{"word":"disappointment","count":1},{"word":"give","count":1},{"word":"lost","count":1},{"word":"sight","count":1},{"word":"started","count":1},{"word":"journey","count":1},{"word":"first","count":1},{"word":"time","count":1},{"word":"happened","count":1},{"word":"call","count":1},{"word":"another","count":1},{"word":"adventure","count":1},{"word":"coming","count":1},{"word":"talked","count":1},{"word":"i'll","count":1},{"word":"take","count":1},{"word":"trips","count":1},{"word":"new","count":1},{"word":"places","count":1},{"word":"course","count":1},{"word":"always","count":1}],"lines":[{"text":"Fuling...!","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"Great news, Fuling! ...I found it! Finally!","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"I've found a way to slow down your illness. No more pain, my love... We can finally be together, forever!","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"Fuling... Are you... Are you not happy?","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"Haha... Yes...","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"Fuling...","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"Rover, Lady Changli...","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"I never properly thanked you for bringing me back to Hongzhen. I heard about the attack by the Fractsidus in the mountains. I... I'm so sorry...","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"As for the truth behind the so-called Secret of Immortality... Fuling has told me everything.","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"I had a gut feeling it would turn out to be a disappointment, but I couldn't give up. And in the end, I lost sight of why I even started this journey...","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"...But this isn't the first time this has happened. Let's just call it another adventure coming to an end.","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"I've talked about it with Fuling. From now on, I'll take her on more trips to see more new places together.","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"Until...","quest_name":"Immortal Blaze","quest_id":121000035},{"text":"Of course, Fuling, I... We've always been...","quest_name":"Immortal Blaze","quest_id":121000035}]}