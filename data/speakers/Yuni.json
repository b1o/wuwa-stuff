{"words":[{"word":"signal","count":2},{"word":"woke","count":1},{"word":"surrounded","count":1},{"word":"toxic","count":1},{"word":"pollen","count":1},{"word":"starving","count":1},{"word":"parched","count":1},{"word":"barely","count":1},{"word":"hanging","count":1},{"word":"gravity","count":1},{"word":"storm","count":1},{"word":"messing","count":1},{"word":"tried","count":1},{"word":"calling","count":1},{"word":"everyone","count":1},{"word":"contacts","count":1},{"word":"lollo","count":1},{"word":"logistics'","count":1},{"word":"number","count":1},{"word":"went","count":1},{"word":"worried","count":1},{"word":"losing","count":1},{"word":"used","count":1},{"word":"automatic","count":1},{"word":"ordering","count":1},{"word":"service","count":1},{"word":"send","count":1},{"word":"request","count":1},{"word":"expect","count":1},{"word":"actually","count":1},{"word":"deliver","count":1},{"word":"trouble","count":1},{"word":"move","count":1},{"word":"around","count":1},{"word":"thanks","count":1},{"word":"i'll","count":1},{"word":"never","count":1},{"word":"forget","count":1},{"word":"help","count":1},{"word":"haha","count":1},{"word":"goodbye","count":1}],"lines":[{"text":"I don't know. I woke up here, surrounded by toxic pollen with no way out. I was starving and parched, barely hanging on.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"The Gravity Storm was messing with my signal... I tried calling everyone in my contacts, but only Lollo Logistics' number went through.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"I was worried about losing the signal, so I used your automatic ordering service to send out the request. I didn't expect you to actually deliver it here.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"No need to trouble yourselves. I can move around now. Thanks so much... I'll never forget your help.","quest_name":"We Promise, We Deliver","quest_id":122000005},{"text":"Haha, I will. Goodbye for now!","quest_name":"We Promise, We Deliver","quest_id":122000005}]}