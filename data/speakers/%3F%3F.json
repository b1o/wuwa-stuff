{"words":[{"word":"i'll","count":5},{"word":"yuanyuan","count":4},{"word":"ano","count":4},{"word":"care","count":3},{"word":"girl","count":3},{"word":"oh","count":3},{"word":"time","count":3},{"word":"hehe","count":3},{"word":"world","count":3},{"word":"stop","count":3},{"word":"enough","count":2},{"word":"lirong","count":2},{"word":"remember","count":2},{"word":"hand","count":2},{"word":"good","count":2},{"word":"smart","count":2},{"word":"mind","count":2},{"word":"hmm","count":2},{"word":"into","count":2},{"word":"trying","count":2},{"word":"fighting","count":2},{"word":"sorry","count":2},{"word":"fun","count":2},{"word":"first","count":2},{"word":"person","count":2},{"word":"potential","count":2},{"word":"keep","count":2},{"word":"mission","count":2},{"word":"bloom","count":2},{"word":"black","count":2},{"word":"shores","count":2},{"word":"save","count":2},{"word":"many","count":2},{"word":"less","count":2},{"word":"nothing","count":2},{"word":"take","count":2},{"word":"any","count":2},{"word":"indulge","count":2},{"word":"i'd","count":2},{"word":"duty","count":2},{"word":"fruits","count":2},{"word":"special","count":2},{"word":"seed","count":2},{"word":"fruit","count":2},{"word":"feel","count":2},{"word":"bit","count":2},{"word":"relax","count":2},{"word":"i've","count":2},{"word":"fractsidus","count":2},{"word":"dirty","count":2},{"word":"hmph","count":2},{"word":"tricks","count":2},{"word":"thank","count":2},{"word":"throat","count":2},{"word":"thou","count":2},{"word":"looking","count":2},{"word":"piece","count":2},{"word":"safe","count":1},{"word":"things","count":1},{"word":"lose","count":1},{"word":"daughter","count":1},{"word":"man","count":1},{"word":"father","count":1},{"word":"separate","count":1},{"word":"whatever","count":1},{"word":"please","count":1},{"word":"stay","count":1},{"word":"concerned","count":1},{"word":"male","count":1},{"word":"boys","count":1},{"word":"female","count":1},{"word":"girls","count":1},{"word":"business","count":1},{"word":"quite","count":1},{"word":"fighter","count":1},{"word":"shh","count":1},{"word":"coming","count":1},{"word":"patrollers","count":1},{"word":"find","count":1},{"word":"trouble","count":1},{"word":"better","count":1},{"word":"explain","count":1},{"word":"everything","count":1},{"word":"later","count":1},{"word":"including","count":1},{"word":"happening","count":1},{"word":"ance","count":1},{"word":"society","count":1},{"word":"choice","count":1},{"word":"pigheaded","count":1},{"word":"pinned","count":1},{"word":"blame","count":1},{"word":"abduct","count":1},{"word":"little","count":1},{"word":"real","count":1},{"word":"talking","count":1},{"word":"give","count":1},{"word":"hide","count":1},{"word":"traces","count":1},{"word":"box","count":1},{"word":"full","count":1},{"word":"surprises","count":1},{"word":"playing","count":1},{"word":"truth-or-dare","count":1},{"word":"oops","count":1},{"word":"getting","count":1},{"word":"angry","count":1},{"word":"rile","count":1},{"word":"pique","count":1},{"word":"interest","count":1},{"word":"great","count":1},{"word":"okay","count":1},{"word":"small","count":1},{"word":"talk","count":1},{"word":"target","count":1},{"word":"bingo","count":1},{"word":"bearers","count":1},{"word":"blake","count":1},{"word":"symbol","count":1},{"word":"represents","count":1},{"word":"says","count":1},{"word":"rules","count":1},{"word":"least","count":1},{"word":"plans","count":1},{"word":"recruit","count":1},{"word":"talents","count":1},{"word":"impending","count":1},{"word":"doom","count":1},{"word":"nuh-uh","count":1},{"word":"going","count":1},{"word":"boom","count":1},{"word":"tomorrow","count":1},{"word":"power","count":1},{"word":"prey","count":1},{"word":"without","count":1},{"word":"mercy","count":1},{"word":"desires","count":1},{"word":"ultimate","count":1},{"word":"pleasure","count":1},{"word":"mean","count":1},{"word":"love","count":1},{"word":"live","count":1},{"word":"alas","count":1},{"word":"calls","count":1},{"word":"garden","count":1},{"word":"home","count":1},{"word":"green","count":1},{"word":"among","count":1},{"word":"nurture","count":1},{"word":"safeguard","count":1},{"word":"seeds","count":1},{"word":"allowing","count":1},{"word":"blossom","count":1},{"word":"luscious","count":1},{"word":"ripens","count":1},{"word":"pick","count":1},{"word":"sweetness","count":1},{"word":"labor","count":1},{"word":"civilization","count":1},{"word":"simulation","count":1},{"word":"sand","count":1},{"word":"table","count":1},{"word":"tethys","count":1},{"word":"told","count":1},{"word":"explosive","count":1},{"word":"within","count":1},{"word":"day","count":1},{"word":"surely","count":1},{"word":"bear","count":1},{"word":"beautiful","count":1},{"word":"imaginable","count":1},{"word":"cold","count":1},{"word":"sound","count":1},{"word":"tempting","count":1},{"word":"push","count":1},{"word":"buttons","count":1},{"word":"behave","count":1},{"word":"edge","count":1},{"word":"anything","count":1},{"word":"strange","count":1},{"word":"actually","count":1},{"word":"diligently","count":1},{"word":"protecting","count":1},{"word":"rid","count":1},{"word":"types","count":1},{"word":"pests","count":1},{"word":"tried","count":1},{"word":"ew","count":1},{"word":"mention","count":1},{"word":"sentence","count":1},{"word":"petty","count":1},{"word":"games","count":1},{"word":"laying","count":1},{"word":"fingers","count":1},{"word":"mine","count":1},{"word":"sharing","count":1},{"word":"couple","count":1},{"word":"fools","count":1},{"word":"flapping","count":1},{"word":"around","count":1},{"word":"headless","count":1},{"word":"chickens","count":1},{"word":"boring","count":1},{"word":"crowd","count":1},{"word":"woah","count":1},{"word":"noticed","count":1},{"word":"enjoyed","count":1},{"word":"nightly","count":1},{"word":"rendezvous","count":1},{"word":"loong","count":1},{"word":"maiden","count":1},{"word":"keeping","count":1},{"word":"people","count":1},{"word":"away","count":1},{"word":"answered","count":1},{"word":"plenty","count":1},{"word":"questions","count":1},{"word":"already","count":1},{"word":"turn","count":1},{"word":"particular","count":1},{"word":"though","count":1},{"word":"almost","count":1},{"word":"forget","count":1},{"word":"cough","count":1},{"word":"entertain","count":1},{"word":"inquiries","count":1},{"word":"blade","count":1},{"word":"anyway","count":1},{"word":"answers","count":1},{"word":"watching","count":1},{"word":"sure","count":1},{"word":"something","count":1},{"word":"oddly","count":1},{"word":"familiar","count":1},{"word":"carry","count":1},{"word":"scent","count":1},{"word":"cartethyia","count":1},{"word":"hello","count":1},{"word":"sounds","count":1},{"word":"odd","count":1},{"word":"confused","count":1},{"word":"trapped","count":1},{"word":"rain","count":1},{"word":"happen","count":1},{"word":"waiting","count":1},{"word":"someone","count":1},{"word":"thanks","count":1},{"word":"embark","count":1},{"word":"journey","count":1},{"word":"together","count":1},{"word":"playername","count":1},{"word":"changli","count":1},{"word":"wayfinder","count":1},{"word":"alright","count":1},{"word":"emilio","count":1},{"word":"band","count":1},{"word":"cowards","count":1},{"word":"decide","count":1},{"word":"handle","count":1},{"word":"pulling","count":1},{"word":"agon","count":1},{"word":"notice","count":1},{"word":"ever","count":1},{"word":"nearly","count":1},{"word":"innocent","count":1},{"word":"killed","count":1},{"word":"shame","count":1},{"word":"boss","count":1},{"word":"serious","count":1},{"word":"sniff","count":1},{"word":"hm","count":1},{"word":"bad","count":1},{"word":"careful","count":1},{"word":"rips","count":1},{"word":"whose","count":1},{"word":"applause","count":1},{"word":"greet","count":1},{"word":"lupa","count":1},{"word":"disgrace","count":1},{"word":"performance","count":1},{"word":"jester","count":1},{"word":"pleased","count":1},{"word":"acquaintance","count":1},{"word":"apologize","count":1},{"word":"delay","count":1},{"word":"name","count":1},{"word":"sanhua","count":1},{"word":"bodyguard","count":1},{"word":"madam","count":1},{"word":"magistrate","count":1},{"word":"guess","count":1},{"word":"self-introduction","count":1},{"word":"aww","count":1},{"word":"spent","count":1},{"word":"music","count":1},{"word":"holds","count":1},{"word":"emotion","count":1},{"word":"heart","count":1},{"word":"grants","count":1},{"word":"meaning","count":1},{"word":"dear","count":1},{"word":"listener","count":1},{"word":"feelings","count":1},{"word":"evoke","count":1},{"word":"wow","count":1},{"word":"valuable","count":1},{"word":"insight","count":1},{"word":"brings","count":1},{"word":"closer","count":1},{"word":"completing","count":1},{"word":"excuse","count":1},{"word":"help","count":1},{"word":"huh","count":1}],"lines":[{"text":"That's enough, Lirong.","quest_name":"Solitary Path","quest_id":114000018},{"text":"She'll be safe in my care. You still have other things to do, remember?","quest_name":"Solitary Path","quest_id":114000018},{"text":"Lirong!","quest_name":"Solitary Path","quest_id":114000018},{"text":"Do you want to lose your daughter again?","quest_name":"Solitary Path","quest_id":114000018},{"text":"Now, hand over the girl…","quest_name":"Solitary Path","quest_id":114000018},{"text":"You see, that man is her father. Why do you want to separate them?","quest_name":"Solitary Path","quest_id":114000018},{"text":"Oh well, whatever. Yuanyuan? Come over here please?","quest_name":"Solitary Path","quest_id":114000018},{"text":"Good girl. Stay here, Yuanyuan.","quest_name":"Solitary Path","quest_id":114000018},{"text":"And why would you be concerned? Smart {Male=boys;Female=girls} know how to mind their own business.","quest_name":"Solitary Path","quest_id":114000018},{"text":"Oh? You're quite the fighter… Hmm, how about…","quest_name":"Solitary Path","quest_id":114000018},{"text":"Shh... They're coming… It's the Patrollers. We can't let them find out about Yuanyuan.","quest_name":"Solitary Path","quest_id":114000018},{"text":"Now if you don't want to get into trouble, better do as I say... I'll explain everything later.","quest_name":"Solitary Path","quest_id":114000018},{"text":"Including what's happening with the \"Séance Society\"…","quest_name":"Solitary Path","quest_id":114000018},{"text":"Smart choice...","quest_name":"Solitary Path","quest_id":114000018},{"text":"Oh, don't be so pigheaded. What if I pinned the blame on you?","quest_name":"Solitary Path","quest_id":114000018},{"text":"Say, for trying to abduct this little girl? You'll have a real time talking your way out of that... Right, Yuanyuan?","quest_name":"Solitary Path","quest_id":114000018},{"text":"Good. Now come give me a hand. We'll need to hide the traces of fighting here.","quest_name":"Solitary Path","quest_id":114000018},{"text":"You're such a box full of surprises.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"So we're playing truth-or-dare now? I see... Oops!","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Hehe... Getting angry, are we? Sorry, but it's just so much fun to rile you up.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"You're the very first person to pique my interest like this. You... have great potential.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Okay, so you're not up for small talk. I'll keep that in mind. You're my mission target, after all.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Bingo! I'm one of the Bloom Bearers of the Black Shores.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"This Blake Bloom is our symbol. It represents our mission to save the world.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"That's what it says in the rules, at least.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Our plans? Hmm... What is it again? To recruit as many talents as we can, and save the world from its impending doom.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"So, are you in?","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Nuh-uh, I don't! The world? Couldn't care less. If it's all going BOOM tomorrow, why not have fun while we can?","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"To stop at nothing for more power, take down any prey without mercy, and indulge in all our desires for the ultimate pleasure...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Well... I mean, I'd love to live that way, but alas, duty calls.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"<ano=The Black Shores>Our \"Garden\"</ano> is home to many green fruits, and we'll make you the most special \"Seed\" among them all...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"My duty is to nurture and safeguard seeds like you, allowing them to blossom into luscious fruits.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Then once the fruit ripens, I'll get to pick it, and indulge the sweetness of my labor all by myself.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"You're just like what <ano=Civilization Simulation Sand Table>Tethys</ano> has told us... I can feel such explosive potential within you. One day, you'll surely bear the most beautiful fruit imaginable.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Hehe... I like how cold you sound. You're tempting me to push your buttons a bit more...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Relax, relax. I'll behave for the time being.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"No need to be so on edge. I won't do anything... strange, to you, I think?","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Actually, I've been diligently protecting you, you know? I got rid of all types of pests that tried to get in your way!","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Ew, don't mention me and the Fractsidus in the same sentence. I couldn't care less about their petty games, but if they even think of laying their dirty fingers on you... Hmph. You're mine, and I don't like sharing.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Just a couple tricks and I had those fools flapping around like headless chickens. What a boring crowd.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Woah, don't tell me you haven't noticed?","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Enjoyed your nightly rendezvous with that Loong Maiden? You have me to thank for keeping those Fractsidus people away.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Well... I've answered plenty of questions already. Now it's your turn.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Hehe, nothing in particular.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"The way you look at me though, it's almost as if... No, forget about it.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"...Cough... Do you think I'd entertain... your inquiries, if I didn't have a blade on my throat?...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Anyway, I'm not trying to get any answers from you...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"But I'll be watching you. You're a very special \"Seed\", that I am very sure.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"I can feel something oddly familiar about you...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Thou...","quest_name":"Flames of Heart","quest_id":121000038},{"text":"Thou carry the scent of Cartethyia.","quest_name":"Flames of Heart","quest_id":121000038},{"text":"...Hello.","quest_name":"Silent as a Falling Leaf","quest_id":122000009},{"text":"Sorry, if this sounds odd, but... I'm a bit confused. I don't remember why I'm here.","quest_name":"Silent as a Falling Leaf","quest_id":122000009},{"text":"Are you trapped here by the rain?","quest_name":"To Mt. Firmament","quest_id":125000121},{"text":"I happen to be waiting for someone, too.","quest_name":"To Mt. Firmament","quest_id":125000121},{"text":"No need for thanks. We're about to embark on a journey together, {PlayerName}.","quest_name":"To Mt. Firmament","quest_id":125000121},{"text":"I am Changli, your \"Wayfinder.\"","quest_name":"To Mt. Firmament","quest_id":125000121},{"text":"Alright, Emilio. Why don't you take your band of cowards and get out of my way before I decide to handle it myself?","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"Pulling dirty tricks before the Agon... did you think I wouldn't notice? Did you ever stop to think you nearly got an innocent person killed? Shame on you!","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"Boss, you're looking so serious!","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"Sniff... Hm?","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"Not bad!","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"Think you can keep me from fighting?","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"Careful now...","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"We'll see who rips whose throat out first.","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"May applause greet you, Lupa.","quest_name":"Shadow of Glory","quest_id":125000125},{"text":"Hmph, enough of this disgrace! Stop your performance, jester!","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"Pleased to make your acquaintance. I apologize for the delay. My name is Sanhua, the bodyguard of Madam Magistrate.","quest_name":"First Resonance","quest_id":139000027},{"text":"Guess you won't need my self-introduction. Aww, I spent so much time on it.","quest_name":"Ominous Star","quest_id":139000030},{"text":"Music itself holds no emotion. It's the heart that grants it meaning. So, dear listener, tell me. What feelings did my piece evoke in you?","quest_name":"The Maiden, The Defier, The Death Crier","quest_id":145000005},{"text":"Wow... A very valuable insight! Thank you, that brings me closer to completing my piece.","quest_name":"The Maiden, The Defier, The Death Crier","quest_id":145000005},{"text":"Excuse me, I… I need your help.","quest_name":"A Blaze in the Dark","quest_id":158800014},{"text":"Huh?!","quest_name":"A Blaze in the Dark","quest_id":158800014},{"text":"Is it... me you're looking for?","quest_name":"A Blaze in the Dark","quest_id":158800014}]}