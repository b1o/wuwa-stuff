{"words":[{"word":"lynae","count":2},{"word":"gift","count":2},{"word":"quicker","count":1},{"word":"expected","count":1},{"word":"hurry","count":1},{"word":"time","count":1},{"word":"main","count":1},{"word":"event","count":1},{"word":"poor","count":1},{"word":"fractsidus","count":1},{"word":"liaison","count":1},{"word":"handled","count":1},{"word":"innocent","count":1},{"word":"researcher","count":1},{"word":"choose","count":1},{"word":"willing","count":1},{"word":"lose","count":1},{"word":"unsure","count":1},{"word":"help","count":1},{"word":"little","count":1},{"word":"oh","count":1},{"word":"nameless","count":1},{"word":"fugitive","count":1},{"word":"unseen","count":1},{"word":"guardian","count":1},{"word":"turn","count":1},{"word":"spacetrek","count":1},{"word":"collective","count":1},{"word":"really","count":1},{"word":"resolute","count":1},{"word":"either","count":1},{"word":"problem","count":1},{"word":"parting","count":1},{"word":"fitting","count":1},{"word":"new","count":1},{"word":"role","count":1},{"word":"always","count":1},{"word":"received","count":1},{"word":"doubt","count":1},{"word":"isolation","count":1}],"lines":[{"text":"You got here quicker than I expected. No hurry. We've got time before the main event.","quest_name":"What Burns Beneath Frostlands","quest_id":915000003},{"text":"The poor Fractsidus liaison you... \"handled\"?","quest_name":"What Burns Beneath Frostlands","quest_id":915000003},{"text":"Or… just an innocent researcher?","quest_name":"What Burns Beneath Frostlands","quest_id":915000003},{"text":"It's all up to you, Lynae—who you choose to be, and what you're willing to lose.","quest_name":"What Burns Beneath Frostlands","quest_id":915000003},{"text":"That look… Still unsure, I see. I could help you out a little.","quest_name":"What Burns Beneath Frostlands","quest_id":915000003},{"text":"Oh? So the \"Nameless Fugitive\" is now the \"Unseen Guardian\"?","quest_name":"What Burns Beneath Frostlands","quest_id":915000003},{"text":"Turn me in, and the Spacetrek Collective will come for you, too. Tell me, Lynae, are you really as resolute as you think?","quest_name":"What Burns Beneath Frostlands","quest_id":915000003},{"text":"Either way, you're a problem for me. So here's a parting gift... one fitting for your new role.","quest_name":"What Burns Beneath Frostlands","quest_id":915000003},{"text":"The same gift you've always received—\"doubt\" and \"isolation.\"","quest_name":"What Burns Beneath Frostlands","quest_id":915000003}]}