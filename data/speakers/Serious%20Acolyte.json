{"words":[{"word":"reserved","count":4},{"word":"rinascita","count":2},{"word":"cooperate","count":2},{"word":"terminal","count":2},{"word":"terminals","count":2},{"word":"approved","count":1},{"word":"welcome","count":1},{"word":"excuse","count":1},{"word":"first-time","count":1},{"word":"visitors","count":1},{"word":"must","count":1},{"word":"inspection","count":1},{"word":"declared","count":1},{"word":"upon","count":1},{"word":"entry","count":1},{"word":"declaration","count":1},{"word":"form","count":1},{"word":"please","count":1},{"word":"rules","count":1},{"word":"i'll","count":1},{"word":"ah","count":1},{"word":"guest","count":1},{"word":"montelli","count":1},{"word":"family","count":1},{"word":"granted","count":1},{"word":"permission","count":1},{"word":"bring","count":1},{"word":"into","count":1},{"word":"apologize","count":1},{"word":"any","count":1},{"word":"trouble","count":1},{"word":"caused","count":1},{"word":"echoes","count":1},{"word":"seen","count":1},{"word":"divine","count":1},{"word":"envoys","count":1},{"word":"baptized","count":1},{"word":"receive","count":1},{"word":"imperator's","count":1},{"word":"blessings","count":1},{"word":"acolyte","count":1},{"word":"phoebe","count":1},{"word":"going","count":1},{"word":"male","count":1},{"word":"female","count":1},{"word":"chamber","count":1}],"lines":[{"text":"...Approved. Welcome to Rinascita.","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"Excuse me. First-time visitors must cooperate for inspection.","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"Is this... a Reserved Terminal?","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"Reserved Terminals should be declared upon entry. May I see your declaration form, please?","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"These are the rules. I'll need you to cooperate.","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"Ah, I see you are a guest of the Montelli family. You are granted permission to bring your Reserved Terminal into Rinascita.","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"We apologize for any trouble caused. All Echoes, even those in Reserved Terminals, are seen as Divine Envoys. Once they are baptized, they too will receive Imperator's blessings.","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"Acolyte Phoebe.","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"You there! What's going on here?","quest_name":"A Blaze in the Dark","quest_id":158800014},{"text":"What about {Male=him;Female=her}?","quest_name":"A Blaze in the Dark","quest_id":158800014},{"text":"Right, you'll come with me to the Chamber then.","quest_name":"A Blaze in the Dark","quest_id":158800014}]}