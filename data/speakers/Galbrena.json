"word":"thundering","count":1},{"word":"mephis","count":1},{"word":"feilian","count":1},{"word":"beringal","count":1},{"word":"native","count":1},{"word":"suspect","count":1},{"word":"corrupted","count":1},{"word":"abby","count":1},{"word":"many","count":1},{"word":"frequencies","count":1},{"word":"tide's","count":1},{"word":"lay","count":1},{"word":"wait","count":1},{"word":"masked","count":1},{"word":"others","count":1},{"word":"makes","count":1},{"word":"sense","count":1},{"word":"life","count":1},{"word":"energy","count":1},{"word":"primary","count":1},{"word":"bond","count":1},{"word":"overriding","count":1},{"word":"abby's","count":1},{"word":"planned","count":1},{"word":"threat","count":1},{"word":"kill","count":1},{"word":"destroy","count":1},{"word":"slowed","count":1},{"word":"maybe","count":1},{"word":"sealed","count":1},{"word":"pathways","count":1},{"word":"resorting","count":1},{"word":"final","count":1},{"word":"so-called","count":1},{"word":"divinity","count":1},{"word":"devious","count":1},{"word":"humanity","count":1},{"word":"realizes","count":1},{"word":"stands","count":1},{"word":"matriarch","count":1},{"word":"fisalia","count":1},{"word":"guarded","count":1},{"word":"truth","count":1},{"word":"century","count":1},{"word":"insight","count":1},{"word":"emotion","count":1},{"word":"stirs","count":1},{"word":"shapes","count":1},{"word":"kept","count":1},{"word":"forcing","count":1},{"word":"into","count":1},{"word":"tragedy","count":1},{"word":"struggle","count":1},{"word":"random","count":1},{"word":"keep","count":1},{"word":"feeding","count":1},{"word":"times","count":1},{"word":"drawing","count":1},{"word":"near","count":1},{"word":"ragunnesi","count":1},{"word":"cling","count":1},{"word":"hopes","count":1},{"word":"blissful","count":1},{"word":"septimontians","count":1},{"word":"long","count":1},{"word":"believed","count":1},{"word":"another","count":1},{"word":"begins","count":1},{"word":"death","count":1},{"word":"drawn","count":1},{"word":"beliefs","count":1},{"word":"aligning","count":1},{"word":"desires","count":1},{"word":"fabricate","count":1},{"word":"false","count":1},{"word":"assimilation","count":1},{"word":"grow","count":1},{"word":"imagination","count":1},{"word":"vanishes","count":1},{"word":"descend","count":1},{"word":"upon","count":1},{"word":"soul","count":1},{"word":"unified","count":1},{"word":"blind","count":1},{"word":"devotion","count":1},{"word":"different","count":1},{"word":"cast","count":1},{"word":"aside","count":1},{"word":"sentinel's","count":1},{"word":"form","count":1},{"word":"took","count":1},{"word":"cartethyia's","count":1},{"word":"means","count":1},{"word":"step","count":1},{"word":"complete","count":1},{"word":"watching","count":1},{"word":"mark","count":1},{"word":"read","count":1},{"word":"full","count":1},{"word":"sensed","count":1},{"word":"connection","count":1},{"word":"runs","count":1},{"word":"imagined","count":1},{"word":"become","count":1},{"word":"vessel","count":1},{"word":"rinascita's","count":1},{"word":"gather","count":1},{"word":"flicker","count":1},{"word":"hunt","count":1},{"word":"war","count":1},{"word":"spirit","count":1},{"word":"light","count":1},{"word":"shadow","count":1},{"word":"belief","count":1},{"word":"unshakable","count":1},{"word":"doubt","count":1},{"word":"heart","count":1},{"word":"stop","count":1},{"word":"reveal","count":1},{"word":"unless","count":1},{"word":"i've","count":1},{"word":"figured","count":1},{"word":"plans","count":1},{"word":"bells","count":1},{"word":"ring","count":1},{"word":"buy","count":1},{"word":"moment","count":1},{"word":"comes","count":1},{"word":"fiction","count":1},{"word":"past","count":1},{"word":"converge","count":1},{"word":"hello","count":1},{"word":"forte-astic","count":1},{"word":"fizz","count":1},{"word":"freeze","count":1},{"word":"extra","count":1},{"word":"large","count":1},{"word":"mix","count":1},{"word":"mint","count":1},{"word":"viscum","count":1},{"word":"berries","count":1},{"word":"mastic","count":1},{"word":"nuvola","count":1},{"word":"cream","count":1},{"word":"proportion","count":1},{"word":"packed","count":1},{"word":"flavor","count":1},{"word":"sharp","count":1},{"word":"cool","count":1},{"word":"ad","count":1},{"word":"everything's","count":1},{"word":"fine","count":1},{"word":"chimera's","count":1},{"word":"keeping","count":1},{"word":"stable","count":1},{"word":"nothing","count":1},{"word":"worry","count":1},{"word":"though","count":1},{"word":"since","count":1},{"word":"essence","count":1},{"word":"chimera","count":1},{"word":"grumbling","count":1},{"word":"nonstop","count":1},{"word":"craving","count":1},{"word":"something","count":1},{"word":"cold","count":1},{"word":"hey","count":1},{"word":"human","count":1},{"word":"allowed","count":1},{"word":"food","count":1},{"word":"ugh","count":1},{"word":"never","count":1},{"word":"mind","count":1},{"word":"manage","count":1},{"word":"split","count":1},{"word":"carry","count":1},{"word":"sometimes","count":1},{"word":"okay","count":1},{"word":"lean","count":1},{"word":"else","count":1},{"word":"side","count":1}],"lines":[{"text":"Well, I'm glad it helped. I'll be on my way then.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"...","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"I see… I'll take it then.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Oh, one more thing. My last Terminal gave out after I… \"used\" it too much. Think the Black Shores could lend me a new one?","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Thanks. Well then… till next time.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"...Angel. That's my real name.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"One wish fulfilled... Alright, time to head to the Black Shores.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"He's the leader of the Ghost Hounds. Strong, ruthless, not someone to cross lightly. I teamed up with him once while hunting in the New Federation.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"He tried to recruit me, but I'm used to working alone, so I turned him down.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"They've got quite the network. I got that lamp Terminal through their channels.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"If you ever find yourself in the New Federation, you'll probably get to know him better.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"It would throw your power completely out of balance. Better to leave it with me.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"And really, I couldn't have done all this alone. Everyone played their part.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Honestly, pulling off a fake assassination in front of two powerful Resonators, without flinching or getting caught... Yes, not exactly a walk in the park.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Luckily, with a clear target, there's always a way to make the shot land. I didn't need to take you on, just sell the scene. \"Blessed Maiden, down in one.\" Easy enough.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Leviathan needs a Harbinger with enough influence to spread Its \"gospel.\" You're the Laureate of Ragunna and the Hero of Heroes in Septimont. That's more than enough to be Its first choice.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Your path overlaps with Avidius. The Tidespawn are shaped by the Harbinger's thoughts and memories. Neither the Thundering Mephis nor the Feilian Beringal are native to Rinascita. So...","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"I suspect... the one corrupted might not be \"you.\"","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Abby must have absorbed many other frequencies. So while the Dark Tide's frequency lay in wait... it was masked by the others.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"It makes sense. You two share life and energy. As the primary in this bond, your frequency has been overriding Abby's... Leviathan planned for this.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"The real threat is Leviathan. If we want to end this for good, we kill It and destroy Its Paradise.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Everything you've done has slowed down or maybe even sealed off some of Its pathways. That's why Leviathan is resorting to Its \"final plan.\"","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"This so-called divinity is more devious than humanity realizes... The Paradise you saw is not of this world. It stands... within the Dark Tide.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Matriarch of Fisalia, you have guarded this truth for over a century. Now... we need your insight.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"The stronger the conflict, the deeper the emotion it stirs. That's what shapes our memories and subconscious...","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"That's why the Playwright kept forcing Rinascita into conflict. Every tragedy, every struggle... it wasn't random. It was all to keep feeding Leviathan.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"The End Times are drawing near. The Ragunnesi cling to hopes of a blissful afterlife. Septimontians have long believed in \"another world\" that begins after death...","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Leviathan may have drawn from these subconscious beliefs, \"aligning\" with those desires to fabricate a false future and afterlife within the Dark Tide—the illusion of the Journeying Paradise.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Its power of assimilation will grow stronger, until the line between imagination and reality vanishes. The Journeying Paradise will descend upon the world, just as before.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"...When it does, every soul in Rinascita will be unified under Its control. No thoughts. No will. Just blind devotion... No different from the Tidespawn.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"You saw it in the illusion. It cast aside the Sentinel's form and took on Cartethyia's. That means... The first step in her plan is complete.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Leviathan is still watching the real world. Because of the \"Mark of the Dark Tide,\" It can read your thoughts. So for now... we can't share the full plan with you.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"But you must have sensed it by now. Your connection with Rinascita runs deeper than I, or even you, ever imagined...","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"You're not just the Harbinger of Despair... You've become a vessel of Rinascita's hope.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"So go. Gather every last flicker of it. This is a \"hunt,\" yes. But it's also more than that. It's a war of spirit. Of light against shadow. Hope against despair.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"To take Leviathan down, our belief has to be unshakable. If there's doubt in your heart... then stop. A new path won't reveal itself unless you're ready to walk it.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"For now, the Dark Tide in Ragunna is under control. And I think... I've figured out what It plans to do next...","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Before the bells of Paradise ring, I'll buy you time. When you're ready, head to Septimont.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Just like the Playwright said, when the moment comes, everything—fiction and reality, past and future—will converge there.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Hello, I'll have one Forte-astic Fizz & Freeze gelato. Extra large. Thanks.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"They say if you mix mint, Viscum Berries, Mastic Nuvola, and cream in just the right proportion, you get a gelato that's not only packed with flavor, but sharp and cool enough to clear your head.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Oh, and the ad said if you say the name in one go, you get 30% off.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Everything's fine, Chimera's keeping it stable. Nothing to worry about for now.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Though ever since I absorbed that essence, Chimera has been grumbling nonstop about craving something cold...","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"...","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Hey, I'm human too, you know. I'm allowed to want good food. Ugh... never mind, let's go.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"I can't manage this on my own. Want to split it?","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"\"You don't have to carry it all yourself. Sometimes, it's okay to lean on someone else.\" Wasn't that your line?","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"So, one side each?","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019}]}