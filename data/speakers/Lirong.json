{"words":[{"word":"yuanyuan","count":11},{"word":"huff","count":4},{"word":"yes","count":3},{"word":"urgh","count":3},{"word":"must","count":2},{"word":"afraid","count":2},{"word":"together","count":2},{"word":"take","count":2},{"word":"alive","count":2},{"word":"leaving","count":2},{"word":"daddy","count":2},{"word":"i'll","count":2},{"word":"always","count":2},{"word":"sure","count":2},{"word":"first","count":2},{"word":"since","count":1},{"word":"lost","count":1},{"word":"someone","count":1},{"word":"male","count":1},{"word":"female","count":1},{"word":"'s","count":1},{"word":"evil","count":1},{"word":"patrollers","count":1},{"word":"safe","count":1},{"word":"daughter","count":1},{"word":"name","count":1},{"word":"precious","count":1},{"word":"absolutely","count":1},{"word":"dear","count":1},{"word":"stay","count":1},{"word":"nothing","count":1},{"word":"ah","count":1},{"word":"separated","count":1},{"word":"unfortunate","count":1},{"word":"turn","count":1},{"word":"events","count":1},{"word":"thanks","count":1},{"word":"ance","count":1},{"word":"society's","count":1},{"word":"help","count":1},{"word":"truly","count":1},{"word":"miracle","count":1},{"word":"reunited","count":1},{"word":"loved","count":1},{"word":"ones","count":1},{"word":"join","count":1},{"word":"never","count":1},{"word":"gone","count":1},{"word":"doctor","count":1},{"word":"anything","count":1},{"word":"shut","count":1},{"word":"hands","count":1},{"word":"ugh","count":1},{"word":"gah","count":1},{"word":"fine","count":1},{"word":"leave","count":1},{"word":"bear","count":1},{"word":"lose","count":1},{"word":"good","count":1},{"word":"girl","count":1},{"word":"okay","count":1},{"word":"find","count":1},{"word":"puppets","count":1},{"word":"every","count":1},{"word":"puppet","count":1},{"word":"finds","count":1},{"word":"home","count":1},{"word":"people","count":1},{"word":"love","count":1},{"word":"freaks","count":1},{"word":"use","count":1},{"word":"experiments","count":1},{"word":"master","count":1},{"word":"dollmaker","count":1},{"word":"betray","count":1},{"word":"belief","count":1},{"word":"anymore","count":1},{"word":"hope","count":1},{"word":"saved","count":1},{"word":"sigh","count":1},{"word":"matter","count":1},{"word":"safety","count":1},{"word":"behind","count":1},{"word":"quick","count":1},{"word":"huh","count":1},{"word":"aaaghhah","count":1},{"word":"eek","count":1},{"word":"gasp","count":1}],"lines":[{"text":"Since you are here, you must have lost someone, too.","quest_name":"Solitary Path","quest_id":114000018},{"text":"Now, Yuanyuan, no need to be afraid… {Male=He;Female=She}'s not one of those evil Patrollers. You're safe with me.","quest_name":"Solitary Path","quest_id":114000018},{"text":"Yes, my daughter… Her name is Yuanyuan. My only precious.","quest_name":"Solitary Path","quest_id":114000018},{"text":"Absolutely, my dear. We will stay together... Nothing can take you from me again...","quest_name":"Solitary Path","quest_id":114000018},{"text":"Ah, yes... Once we were separated by an unfortunate turn of events... But now I have her back, thanks to the Séance Society's help...","quest_name":"Solitary Path","quest_id":114000018},{"text":"Truly a miracle, is it not?!","quest_name":"Solitary Path","quest_id":114000018},{"text":"And you… Yes, you too can be reunited with your loved ones... Just come join us...","quest_name":"Solitary Path","quest_id":114000018},{"text":"No! She didn't... She was never gone!","quest_name":"Solitary Path","quest_id":114000018},{"text":"Can't you see? Yuanyuan, she... She's still alive! Alive and well!","quest_name":"Solitary Path","quest_id":114000018},{"text":"No! No doctor! I don't need anything!!","quest_name":"Solitary Path","quest_id":114000018},{"text":"I am not leaving her… You're not leaving daddy, right Yuanyuan?","quest_name":"Solitary Path","quest_id":114000018},{"text":"Yuanyuan!","quest_name":"Solitary Path","quest_id":114000018},{"text":"Shut up! Take your hands off her NOW!","quest_name":"Solitary Path","quest_id":114000018},{"text":"Urgh…!?","quest_name":"Solitary Path","quest_id":114000018},{"text":"Huff... Ugh... No! Don't! Yuanyuan!","quest_name":"Solitary Path","quest_id":114000018},{"text":"Urgh… Gah… No, I... Fine, I'll leave it to you.","quest_name":"Solitary Path","quest_id":114000018},{"text":"Yuanyuan!! I was so afraid… I can't bear to lose you again…","quest_name":"Solitary Path","quest_id":114000018},{"text":"No, you're always a good girl... always...","quest_name":"Solitary Path","quest_id":114000018},{"text":"No! You're not! Yuanyuan, I...","quest_name":"Solitary Path","quest_id":114000018},{"text":"You...!","quest_name":"Solitary Path","quest_id":114000018},{"text":"Huff... Huff... I…","quest_name":"Solitary Path","quest_id":114000018},{"text":"No! I won't let you have them!","quest_name":"Solitary Path","quest_id":114000018},{"text":"It's okay, Yuanyuan... They won't find us here.","quest_name":"Solitary Path","quest_id":114000018},{"text":"Not just you, Yuanyuan... They want all the puppets here. But I won't let them.","quest_name":"Solitary Path","quest_id":114000018},{"text":"I'll make sure every puppet finds home, together with people who love and need them. I will NOT let those freaks use them for experiments!","quest_name":"Solitary Path","quest_id":114000018},{"text":"Master Dollmaker… How could you be the first to betray our belief...","quest_name":"Solitary Path","quest_id":114000018},{"text":"I... I'm not sure anymore. He was our hope... He saved us all, but...","quest_name":"Solitary Path","quest_id":114000018},{"text":"*sigh* Doesn't matter now. I must get all of you to safety first.","quest_name":"Solitary Path","quest_id":114000018},{"text":"Yuanyuan, get behind Daddy, quick...","quest_name":"Solitary Path","quest_id":114000018},{"text":"Huh… Urgh… Huff... I will not... Let you! Aaaghhah!","quest_name":"Solitary Path","quest_id":114000018},{"text":"Eek… *gasp*…","quest_name":"Solitary Path","quest_id":114000018}]}