{"words":[{"word":"playername","count":4},{"word":"verification","count":4},{"word":"hong","count":3},{"word":"hard","count":3},{"word":"jinzhou","count":3},{"word":"refinery","count":3},{"word":"tower","count":3},{"word":"reboot","count":3},{"word":"symbol","count":3},{"word":"line","count":3},{"word":"uncle","count":2},{"word":"take","count":2},{"word":"samples","count":2},{"word":"heard","count":2},{"word":"time","count":2},{"word":"journal","count":2},{"word":"haha","count":2},{"word":"lei'li","count":2},{"word":"infinity","count":2},{"word":"space","count":2},{"word":"play","count":2},{"word":"life","count":2},{"word":"used","count":2},{"word":"yes","count":2},{"word":"done","count":2},{"word":"drawing","count":2},{"word":"start","count":2},{"word":"grid","count":2},{"word":"hand","count":2},{"word":"draw","count":2},{"word":"coordinates","count":2},{"word":"getting","count":1},{"word":"older","count":1},{"word":"become","count":1},{"word":"unpredictable","count":1},{"word":"pin","count":1},{"word":"normal","count":1},{"word":"day","count":1},{"word":"far","count":1},{"word":"rest","count":1},{"word":"center","count":1},{"word":"mine","count":1},{"word":"offline","count":1},{"word":"minerals","count":1},{"word":"require","count":1},{"word":"processing","count":1},{"word":"ministry's","count":1},{"word":"working","count":1},{"word":"solution","count":1},{"word":"follow","count":1},{"word":"steps","count":1},{"word":"unlock","count":1},{"word":"console","count":1},{"word":"everything","count":1},{"word":"smoothly","count":1},{"word":"good","count":1},{"word":"co-worker","count":1},{"word":"thought","count":1},{"word":"find","count":1},{"word":"difficulties","count":1},{"word":"passing","count":1},{"word":"came","count":1},{"word":"looks","count":1},{"word":"fight","count":1},{"word":"feels","count":1},{"word":"happen","count":1},{"word":"researcher","count":1},{"word":"mentor","count":1},{"word":"never","count":1},{"word":"argument","count":1},{"word":"fact","count":1},{"word":"always","count":1},{"word":"respected","count":1},{"word":"taught","count":1},{"word":"important","count":1},{"word":"lesson","count":1},{"word":"science","count":1},{"word":"cold","count":1},{"word":"numbers","count":1},{"word":"room","count":1},{"word":"imagination","count":1},{"word":"across","count":1},{"word":"research","count":1},{"word":"scholars","count":1},{"word":"radio","count":1},{"word":"waves","count":1},{"word":"moving","count":1},{"word":"shown","count":1},{"word":"sci-fi","count":1},{"word":"long","count":1},{"word":"ago","count":1},{"word":"symbolizing","count":1},{"word":"twist","count":1},{"word":"dimensions","count":1},{"word":"example","count":1},{"word":"crossed","count":1},{"word":"mind","count":1},{"word":"theater","count":1},{"word":"interested","count":1},{"word":"catastrophe","count":1},{"word":"humanity","count":1},{"word":"send","count":1},{"word":"home","count":1},{"word":"planet","count":1},{"word":"journey","count":1},{"word":"hint","count":1},{"word":"connection","count":1},{"word":"digital","count":1},{"word":"reality","count":1},{"word":"single","count":1},{"word":"different","count":1},{"word":"ways","count":1},{"word":"create","count":1},{"word":"colorful","count":1},{"word":"worlds","count":1},{"word":"bit","count":1},{"word":"grasp","count":1},{"word":"though","count":1},{"word":"many","count":1},{"word":"truths","count":1},{"word":"wild","count":1},{"word":"imaginative","count":1},{"word":"ideas","count":1},{"word":"thinking","count":1},{"word":"gets","count":1},{"word":"fired","count":1},{"word":"responds","count":1},{"word":"nonsense","count":1},{"word":"completely","count":1},{"word":"ignores","count":1},{"word":"anything","count":1},{"word":"seems","count":1},{"word":"unlikely","count":1},{"word":"probability","count":1},{"word":"small","count":1},{"word":"makes","count":1},{"word":"sense","count":1},{"word":"hahaha","count":1},{"word":"lot","count":1},{"word":"issue","count":1},{"word":"console's","count":1},{"word":"process","count":1},{"word":"random","count":1},{"word":"images","count":1},{"word":"generated","count":1},{"word":"put","count":1},{"word":"system","count":1},{"word":"connect","count":1},{"word":"touch","count":1},{"word":"repeated","count":1},{"word":"recorded","count":1},{"word":"order","count":1},{"word":"direction","count":1},{"word":"passed","count":1},{"word":"try","count":1},{"word":"map","count":1},{"word":"asked","count":1},{"word":"ah","count":1},{"word":"triangulation","count":1},{"word":"approach","count":1},{"word":"three","count":1},{"word":"circles","count":1},{"word":"regions","count":1},{"word":"centers","count":1},{"word":"overlapping","count":1},{"word":"area","count":1},{"word":"likely","count":1},{"word":"really","count":1},{"word":"narrows","count":1},{"word":"things","count":1},{"word":"great","count":1},{"word":"idea","count":1},{"word":"oh","count":1},{"word":"finished","count":1},{"word":"procedures","count":1},{"word":"however","count":1},{"word":"today","count":1}],"lines":[{"text":"Uncle Hong is getting older and has become more unpredictable. It's hard to pin him down, even on a normal day.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"Jinzhou is not far from here. You can take some rest there.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"The Refinery Tower at the center of the Mine is offline, but some minerals require it for processing.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"So do the Ministry's samples. Right now, we're working on a solution to reboot the Refinery Tower.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"Just follow the steps to unlock the console and everything should go smoothly. Good to see you again, {PlayerName}.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"I heard from a co-worker about what you're up to, and I thought you might find difficulties in passing the verification, so I came.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"Looks like I'm right on time.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"A fight? The journal? Haha, may I see the journal myself?","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"This feels like what would happen between me and Lei'li, but that researcher isn't me.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"Uncle Hong is like a mentor to me, so I would never have an argument like that with him.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"In fact, I have always respected him because he taught me an important lesson.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"In science, it's not just about cold, hard numbers. There's also room for imagination.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"Like when we come across infinity in our research. To some scholars, that infinity symbol might look like radio waves moving through space.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"It was even shown in a Jinzhou sci-fi play not long ago, symbolizing a twist in the dimensions of life.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"Haha. It's just an example that just crossed my mind. You can have a look yourself at the Jinzhou Theater if you're interested.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"The play was about a catastrophe. Humanity had to send their home planet on a journey through space. It used the symbol to hint at the connection between digital life and reality.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"A single symbol can be used in different ways to create colorful worlds. Might be a bit hard to grasp now, though.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"But so many truths come from these wild, imaginative ideas. Just thinking about it gets me all fired up.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"But Lei'li? He just responds with \"That's all nonsense\" and completely ignores anything that seems unlikely.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"So you've heard about it? Yes. Even if the probability is as small as 0.0001%, it still makes sense to me.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"Hahaha, you do know a lot, {PlayerName}. Now let's get on with the issue with the Refinery Tower.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"The console's verification is done by line drawing. When you start the verification process, random images will be generated on a grid.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"You have to put your hand on the grid, and the system will draw a line to connect the coordinates you touch. Repeated coordinates will not be recorded.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"Only when the order and the direction of the line you draw is right, the verification is passed. All right, let's have a try.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"You're here. {PlayerName}, this is the map you asked for.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"Ah yes! A triangulation approach.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"By drawing three circles with the regions as centers, the overlapping area is where Hong is most likely to be.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"That really narrows things down. Great idea!","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"Oh, by the way, you can hand me the samples now, {PlayerName}. When the reboot is finished, we will start the procedures.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003},{"text":"However, it can't be done today, as the reboot can take some time.","quest_name":"Hidden Dangers in Peaceful Life","quest_id":134000003}]}