{"words":[{"word":"banners","count":4},{"word":"beep","count":3},{"word":"boost","count":3},{"word":"caution","count":3},{"word":"banner","count":2},{"word":"activate","count":2},{"word":"tacet","count":2},{"word":"discords","count":2},{"word":"behold","count":1},{"word":"conquest","count":1},{"word":"provided","count":1},{"word":"septimont","count":1},{"word":"agon","count":1},{"word":"committee","count":1},{"word":"help","count":1},{"word":"clear","count":1},{"word":"small","count":1},{"word":"directly","count":1},{"word":"large","count":1},{"word":"activated","count":1},{"word":"nearby","count":1},{"word":"course","count":1},{"word":"provide","count":1},{"word":"greater","count":1},{"word":"claimed","count":1},{"word":"stronger","count":1},{"word":"enemies","count":1},{"word":"guard","count":1},{"word":"easy","count":1},{"word":"tackle","count":1},{"word":"defeat","count":1},{"word":"reclaim","count":1},{"word":"areas","count":1},{"word":"scattered","count":1},{"word":"across","count":1},{"word":"old","count":1},{"word":"district","count":1},{"word":"waiting","count":1},{"word":"discover","count":1},{"word":"challenge","count":1},{"word":"goal","count":1},{"word":"caught","count":1},{"word":"real","count":1},{"word":"quick","count":1},{"word":"onward","count":1},{"word":"fearless","count":1},{"word":"gladiator","count":1},{"word":"stand","count":1},{"word":"tall","count":1},{"word":"victory","count":1},{"word":"always","count":1},{"word":"calls","count":1},{"word":"showered","count":1},{"word":"cheers","count":1},{"word":"triumph","count":1}],"lines":[{"text":"Beep... Behold! This is the Banner of Conquest, provided by the Septimont Agon Committee. Activate it, and it'll help you clear the Tacet Discords!","quest_name":"Banners Never Fall","quest_id":133000011},{"text":"For these small banners, you can activate them directly.","quest_name":"Banners Never Fall","quest_id":133000011},{"text":"A large banner like this can only be activated when no Tacet Discords are nearby. Of course, it'll provide a greater boost boost boost! Beep—","quest_name":"Banners Never Fall","quest_id":133000011},{"text":"Caution caution caution! Some banners have been claimed by stronger enemies! Don't let your guard down! They're not easy to tackle! But if you can defeat them, we'll reclaim those areas!","quest_name":"Banners Never Fall","quest_id":133000011},{"text":"These banners are scattered across the Old District, waiting for you to discover! Beep!","quest_name":"Banners Never Fall","quest_id":133000011},{"text":"So, in this challenge, our goal is—","quest_name":"Banners Never Fall","quest_id":133000011},{"text":"That's right! You caught on real quick! Onward, Fearless Gladiator! The banners stand tall, victory always calls! May you be showered in the cheers of triumph!","quest_name":"Banners Never Fall","quest_id":133000011}]}