{"words":[{"word":"love","count":4},{"word":"captain","count":1},{"word":"wrong","count":1},{"word":"take","count":1},{"word":"joke","count":1},{"word":"step","count":1},{"word":"aside","count":1},{"word":"light","count":1},{"word":"life","count":1},{"word":"storm","count":1},{"word":"keep","count":1},{"word":"apart","count":1},{"word":"presence","count":1},{"word":"withstand","count":1},{"word":"any","count":1},{"word":"tempest","count":1},{"word":"stronger","count":1},{"word":"soul","count":1},{"word":"yearns","count":1},{"word":"break","count":1},{"word":"free","count":1},{"word":"found","count":1},{"word":"direction","count":1},{"word":"yet","count":1},{"word":"tormented","count":1},{"word":"inability","count":1},{"word":"reach","count":1},{"word":"oh","count":1},{"word":"dearest","count":1}],"lines":[{"text":"You see, Captain. What did I tell you?","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"No, no, no! You're all doing it wrong!","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"What do you take love for? Is this a joke to you?","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"Step aside!","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"My love. You are the light of my life.","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"No storm can keep us apart, for in your presence, the might of my love can withstand any tempest, for it is even stronger!","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"My soul yearns to break free, for it has found its direction, yet I am tormented by my inability to reach you...","quest_name":"Old Man and the Whale","quest_id":880000038},{"text":"Oh, my dearest love—","quest_name":"Old Man and the Whale","quest_id":880000038}]}