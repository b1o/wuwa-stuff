{"words":[{"word":"i'll","count":5},{"word":"hurt","count":3},{"word":"world","count":2},{"word":"always","count":2},{"word":"protect","count":2},{"word":"huh","count":1},{"word":"fall","count":1},{"word":"asleep","count":1},{"word":"paper","count":1},{"word":"plane","count":1},{"word":"show","count":1},{"word":"playername","count":1},{"word":"leaving","count":1},{"word":"promise","count":1},{"word":"wait","count":1},{"word":"lahai-roi","count":1},{"word":"b-but","count":1},{"word":"live","count":1},{"word":"many","count":1},{"word":"years","count":1},{"word":"gone","count":1},{"word":"time","count":1},{"word":"return","count":1},{"word":"sorry","count":1},{"word":"said","count":1},{"word":"fair","count":1},{"word":"saving","count":1},{"word":"exhausted","count":1},{"word":"getting","count":1},{"word":"someday","count":1},{"word":"yes","count":1},{"word":"invincible","count":1},{"word":"tired","count":1},{"word":"sad","count":1},{"word":"everyone","count":1},{"word":"else","count":1},{"word":"chase","count":1},{"word":"anyone","count":1},{"word":"tries","count":1},{"word":"katya","count":1},{"word":"space","count":1},{"word":"fantasy","count":1},{"word":"become","count":1},{"word":"savior","count":1},{"word":"laugh","count":1},{"word":"serious","count":1}],"lines":[{"text":"...Huh? When did I fall asleep...","quest_name":"The Star That Voyages Far","quest_id":114000031},{"text":"My paper plane... I have to show it to {PlayerName}...","quest_name":"The Star That Voyages Far","quest_id":114000031},{"text":"Are you leaving now?","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"When... when will you come back?","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"You promise?","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"Then… I'll wait for you here in Lahai-Roi.","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"B-but… you can live for so, so many years. What if I'm gone by the time you return—","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"…Sorry. I shouldn't have said that. You should go now.","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"Just go!","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"…It's not fair. Why does it have to be you saving the world? You're always so exhausted… always getting hurt…","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"Then… I'll be the one to protect you someday.","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"Yes! You're not invincible! You get hurt, you get tired, you get sad… you're just like everyone else in this world.","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"So I'll protect you.","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"I'll chase off anyone who tries to hurt you! Like Katya from Space Fantasy!","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"I'll become a savior, just like you.","quest_name":"The Star That Voyages Far","quest_id":114000032},{"text":"Don't laugh! I'm serious!","quest_name":"The Star That Voyages Far","quest_id":114000032}]}