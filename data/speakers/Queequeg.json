{"words":[{"word":"ship","count":4},{"word":"captain","count":3},{"word":"almost","count":2},{"word":"fixed","count":2},{"word":"thank","count":2},{"word":"fine","count":2},{"word":"enough","count":1},{"word":"bring","count":1},{"word":"material","count":1},{"word":"queequeg","count":1},{"word":"fix","count":1},{"word":"half","count":1},{"word":"captain's","count":1},{"word":"orders","count":1},{"word":"working","count":1},{"word":"long","count":1},{"word":"repaired","count":1},{"word":"big","count":1},{"word":"fish","count":1},{"word":"serene","count":1},{"word":"bay","count":1},{"word":"failed","count":1},{"word":"careful","count":1},{"word":"time","count":1},{"word":"pequod","count":1},{"word":"needs","count":1},{"word":"ahab","count":1},{"word":"anymore","count":1}],"lines":[{"text":"Now not enough.","quest_name":"Love in the Time of Fishing","quest_id":880000036},{"text":"You bring material. Queequeg fix ship.","quest_name":"Love in the Time of Fishing","quest_id":880000036},{"text":"Ship almost fixed up. Thank you. Only half to go.","quest_name":"Where All Fish Converge","quest_id":880000037},{"text":"Captain's orders. Almost working.","quest_name":"Where All Fish Converge","quest_id":880000037},{"text":"As long ship is repaired, will be fine. All will be fine.","quest_name":"Where All Fish Converge","quest_id":880000037},{"text":"By the way, that big \"fish.\" Serene Bay.","quest_name":"Where All Fish Converge","quest_id":880000037},{"text":"We failed before. You be careful.","quest_name":"Where All Fish Converge","quest_id":880000037},{"text":"The ship is fixed. Thank you. It is time.","quest_name":"Old Man and the Whale","quest_id":880700011},{"text":"Pequod, needs a captain.","quest_name":"Old Man and the Whale","quest_id":880700011},{"text":"If Ahab not captain anymore, then... we still need a captain.","quest_name":"Old Man and the Whale","quest_id":880700011}]}