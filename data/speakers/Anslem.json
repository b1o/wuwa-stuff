{"words":[{"word":"dr","count":2},{"word":"herssen","count":2},{"word":"really","count":1},{"word":"remember","count":1},{"word":"anything","count":1},{"word":"campus","count":1},{"word":"doctor","count":1},{"word":"protect","count":1},{"word":"never","count":1},{"word":"mind","count":1},{"word":"time","count":1},{"word":"academy's","count":1},{"word":"review","count":1},{"word":"committee","count":1},{"word":"thinks","count":1},{"word":"i've","count":1},{"word":"said","count":1},{"word":"unbelievable","count":1},{"word":"willing","count":1},{"word":"trust","count":1},{"word":"passed","count":1},{"word":"saw","count":1},{"word":"certain","count":1},{"word":"warren","count":1},{"word":"optimal","count":1},{"word":"window","count":1},{"word":"derived","count":1},{"word":"indecipherable","count":1},{"word":"runes","count":1},{"word":"methodology","count":1},{"word":"disclosed","count":1},{"word":"advanced","count":1},{"word":"computational","count":1},{"word":"systems","count":1},{"word":"failed","count":1},{"word":"decipher","count":1},{"word":"process","count":1},{"word":"hmph","count":1},{"word":"fine","count":1},{"word":"words","count":1},{"word":"forget","count":1},{"word":"warned","count":1}],"lines":[{"text":"Dr. Herssen, I really can't remember anything...","quest_name":"Ode to the Second Sunrise","quest_id":155000003},{"text":"Aren't you the campus doctor? And you're... here to protect me?","quest_name":"Ode to the Second Sunrise","quest_id":155000003},{"text":"Who's that?","quest_name":"Ode to the Second Sunrise","quest_id":155000003},{"text":"Never mind. No time to think about that.","quest_name":"Ode to the Second Sunrise","quest_id":155000003},{"text":"Dr. Herssen, the Academy's review committee thinks what I've said is unbelievable. But if you're willing to trust me...","quest_name":"Ode to the Second Sunrise","quest_id":155000003},{"text":"Before I passed out, I saw... myself.","quest_name":"Ode to the Second Sunrise","quest_id":155000003},{"text":"How can you be so certain, Warren? Their \"optimal window\" is derived from those indecipherable runes, with no methodology disclosed. Even our most advanced computational systems have failed to decipher their process!","quest_name":"What Burns Beneath Frostlands","quest_id":915000003},{"text":"Hmph, fine words… Just don't forget that I warned you.","quest_name":"What Burns Beneath Frostlands","quest_id":915000003}]}