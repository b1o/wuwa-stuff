{"words":[{"word":"tacet","count":9},{"word":"rider","count":6},{"word":"mark","count":6},{"word":"young","count":5},{"word":"core","count":5},{"word":"incinero","count":5},{"word":"inferno","count":4},{"word":"lollo","count":4},{"word":"logistics","count":4},{"word":"petal","count":3},{"word":"pollen","count":3},{"word":"brought","count":3},{"word":"discord","count":3},{"word":"must","count":3},{"word":"sea","count":3},{"word":"flames","count":3},{"word":"male","count":2},{"word":"man","count":2},{"word":"female","count":2},{"word":"lady","count":2},{"word":"rushing","count":2},{"word":"nearly","count":2},{"word":"gravity","count":2},{"word":"observatory","count":2},{"word":"port","count":2},{"word":"city","count":2},{"word":"guixu","count":2},{"word":"guys","count":2},{"word":"good","count":2},{"word":"petals","count":2},{"word":"seems","count":2},{"word":"i've","count":2},{"word":"wanted","count":2},{"word":"defeat","count":2},{"word":"help","count":2},{"word":"playername","count":2},{"word":"yes","count":2},{"word":"old","count":2},{"word":"poster","count":2},{"word":"sorry","count":2},{"word":"transforming","count":1},{"word":"into","count":1},{"word":"flaming","count":1},{"word":"destination","count":1},{"word":"unyielding","count":1},{"word":"conviction","count":1},{"word":"charge","count":1},{"word":"aah","count":1},{"word":"beautiful","count":1},{"word":"story","count":1},{"word":"observations","count":1},{"word":"show","count":1},{"word":"completely","count":1},{"word":"deactivated","count":1},{"word":"toxin","count":1},{"word":"almost","count":1},{"word":"disappeared","count":1},{"word":"dangerous","count":1},{"word":"storms","count":1},{"word":"gathering","count":1},{"word":"vanished","count":1},{"word":"confidently","count":1},{"word":"conclude","count":1},{"word":"jinzhou","count":1},{"word":"safe","count":1},{"word":"hey","count":1},{"word":"rover","count":1},{"word":"awake","count":1},{"word":"weather","count":1},{"word":"passed","count":1},{"word":"