{"words":[{"word":"school","count":2},{"word":"something","count":2},{"word":"keep","count":2},{"word":"always","count":1},{"word":"hmm","count":1},{"word":"skipping","count":1},{"word":"mean","count":1},{"word":"explain","count":1},{"word":"help","count":1},{"word":"attending","count":1},{"word":"classes","count":1},{"word":"supposed","count":1},{"word":"teaching","count":1},{"word":"practical","count":1},{"word":"life","count":1},{"word":"skills","count":1},{"word":"learn","count":1},{"word":"interesting","count":1},{"word":"teach","count":1},{"word":"old","count":1},{"word":"man","count":1},{"word":"new","count":1},{"word":"anyway","count":1},{"word":"really","count":1},{"word":"issues","count":1},{"word":"mine","count":1},{"word":"recently","count":1},{"word":"promise","count":1},{"word":"settled","count":1},{"word":"spend","count":1},{"word":"time","count":1},{"word":"together","count":1},{"word":"okay","count":1},{"word":"yes","count":1},{"word":"i'll","count":1},{"word":"word","count":1},{"word":"stay","count":1}],"lines":[{"text":"What do I always tell you, hmm? Why are you skipping school?","quest_name":"Time to Study","quest_id":11000031},{"text":"What do you mean by that? Explain yourself.","quest_name":"Time to Study","quest_id":11000031},{"text":"You can help me by attending your classes, you know!","quest_name":"Time to Study","quest_id":11000031},{"text":"They're supposed to be teaching you practical life skills. If you learn something interesting, you can even teach your old man something new!","quest_name":"Time to Study","quest_id":11000031},{"text":"Anyway... there really are issues at the mine recently. I promise you, once they are settled, we'll spend more time together, okay?","quest_name":"Time to Study","quest_id":11000031},{"text":"Yes. I'll keep my word. But before that, you need to keep yours and stay in school!","quest_name":"Time to Study","quest_id":11000031}]}