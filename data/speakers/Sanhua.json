stable","count":1},{"word":"battle","count":1},{"word":"limit","count":1},{"word":"discussion","count":1},{"word":"select","count":1},{"word":"captured","count":1},{"word":"claimed","count":1},{"word":"fractsidus","count":1},{"word":"imprisoned","count":1},{"word":"lost","count":1},{"word":"track","count":1},{"word":"ju","count":1},{"word":"danger","count":1},{"word":"someone","count":1},{"word":"malicious","count":1},{"word":"intent","count":1},{"word":"obtains","count":1},{"word":"potential","count":1},{"word":"consequences","count":1},{"word":"catastrophic","count":1},{"word":"previous","count":1},{"word":"invasion","count":1},{"word":"order","count":1},{"word":"investigate","count":1},{"word":"sentinel's","count":1},{"word":"recorded","count":1},{"word":"location","count":1},{"word":"traveled","count":1},{"word":"looming","count":1},{"word":"threat","count":1},{"word":"discouraged","count":1},{"word":"additional","count":1},{"word":"divertion","count":1},{"word":"human","count":1},{"word":"resources","count":1},{"word":"furthermore","count":1},{"word":"force","count":1},{"word":"viable","count":1},{"word":"solution","count":1},{"word":"trusts","count":1},{"word":"beyond","count":1},{"word":"authorization","count":1},{"word":"meddle","count":1},{"word":"however","count":1},{"word":"landscape","count":1},{"word":"complex","count":1},{"word":"accompanied","count":1},{"word":"special","count":1},{"word":"wayfinder","count":1},{"word":"navigate","count":1},{"word":"likely","count":1},{"word":"whining","count":1},{"word":"aix's","count":1},{"word":"mire","count":1},{"word":"reach","count":1},{"word":"lack","count":1},{"word":"level","count":1},{"word":"understanding","count":1},{"word":"utmost","count":1},{"word":"public","count":1},{"word":"matters","count":1},{"word":"worry","count":1},{"word":"safety","count":1},{"word":"video","count":1},{"word":"message","count":1},{"word":"seemed","count":1},{"word":"weaker","count":1},{"word":"usual","count":1},{"word":"despite","count":1},{"word":"efforts","count":1},{"word":"maintain","count":1},{"word":"composure","count":1},{"word":"optimistic","count":1},{"word":"dangerous","count":1},{"word":"place","count":1},{"word":"take","count":1},{"word":"care","count":1},{"word":"sent","count":1},{"word":"coordinates","count":1},{"word":"thank","count":1},{"word":"kind","count":1},{"word":"pray","count":1},{"word":"prior","count":1},{"word":"departure","count":1},{"word":"instructed","count":1},{"word":"bring","count":1},{"word":"gift","count":1},{"word":"advised","count":1},{"word":"explore","count":1},{"word":"represent","count":1},{"word":"absence","count":1},{"word":"acquire","count":1},{"word":"sooner","count":1},{"word":"apologize","count":1},{"word":"inconvenience","count":1},{"word":"days'","count":1},{"word":"sorry","count":1},{"word":"disclose","count":1},{"word":"eagerly","count":1},{"word":"looking","count":1},{"word":"forward","count":1},{"word":"inability","count":1},{"word":"provide","count":1},{"word":"better","count":1},{"word":"answer","count":1},{"word":"moment","count":1},{"word":"forgotten","count":1},{"word":"knowing","count":1},{"word":"exactly","count":1},{"word":"arrive","count":1},{"word":"without","count":1},{"word":"chance","count":1},{"word":"require","count":1},{"word":"least","count":1},{"word":"complete","count":1},{"word":"current","count":1},{"word":"wanted","count":1},{"word":"assure","count":1},{"word":"means","count":1},{"word":"convey","count":1},{"word":"kindness","count":1},{"word":"accept","count":1},{"word":"sincerest","count":1},{"word":"gratitude","count":1},{"word":"hope","count":1},{"word":"assistance","count":1},{"word":"rush","count":1},{"word":"decision","count":1},{"word":"pressure","count":1},{"word":"into","count":1},{"word":"anything","count":1},{"word":"invite","count":1},{"word":"making","count":1},{"word":"commitment","count":1},{"word":"intention","count":1},{"word":"confuse","count":1},{"word":"puzzles","count":1},{"word":"instead","count":1},{"word":"serve","count":1},{"word":"clues","count":1},{"word":"lead","count":1},{"word":"toward","count":1},{"word":"truth","count":1},{"word":"deeply","count":1},{"word":"regrets","count":1},{"word":"deliver","count":1},{"word":"messages","count":1},{"word":"value","count":1},{"word":"presence","count":1},{"word":"far","count":1},{"word":"imagine","count":1},{"word":"goes","count":1},{"word":"since","count":1},{"word":"confirmation","count":1},{"word":"exceptional","count":1},{"word":"regarding","count":1},{"word":"living","count":1},{"word":"beings","count":1},{"word":"rather","count":1},{"word":"thing","count":1},{"word":"share","count":1},{"word":"frequency","count":1},{"word":"authentic","count":1},{"word":"original","count":1},{"word":"form","count":1},{"word":"apologies","count":1},{"word":"description","count":1},{"word":"accurate","count":1},{"word":"appear","count":1},{"word":"different","count":1},{"word":"unharmed","count":1},{"word":"anticipated","count":1},{"word":"try","count":1},{"word":"kill","count":1},{"word":"stayed","count":1},{"word":"asked","count":1},{"word":"everything","count":1},{"word":"alright","count":1},{"word":"end","count":1},{"word":"stay","count":1},{"word":"safe","count":1},{"word":"dare","count":1},{"word":"watch","count":1},{"word":"continue","count":1},{"word":"protecting","count":1},{"word":"rover","count":1},{"word":"changli","count":1},{"word":"leaving","count":1},{"word":"capital","count":1},{"word":"intrusion","count":1},{"word":"male","count":1},{"word":"female","count":1},{"word":"faced","count":1},{"word":"ambush","count":1},{"word":"central","count":1},{"word":"plains","count":1},{"word":"matter","count":1},{"word":"happens","count":1},{"word":"sword","count":1},{"word":"always","count":1}],"lines":[{"text":"Greetings, {PlayerName}.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"What can I help you with today?","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"I regret to inform you that Madam Magistrate is not in the City Hall. She has left for Mt. Firmament.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"In fact... We have not heard back from her for days.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"Unfortunately, no. Please keep this confidential. The situation in Jinzhou is still unstable after our battle with the Threnodian. We must limit discussion of the Magistrate's whereabouts to a select few.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"When we captured Scar, he claimed that the Fractsidus has imprisoned our Sentinel.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"It was around the same time that Madam Magistrate lost track of Sentinel Jué.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"If our Sentinel is truly in danger… Or if someone with malicious intent obtains this information, the potential consequences could be as catastrophic as the previous Threnodian invasion.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"In order to investigate the Sentinel's whereabouts, Madam Magistrate has left for Mt. Firmament, its last recorded location.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"Madam Magistrate traveled to Mt. Firmament alone.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"The looming threat of the Threnodian discouraged any additional divertion of human resources. Furthermore, when it comes to the Sentinel, force is not a viable solution.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"Madam Magistrate trusts you. It is beyond my authorization to meddle in your decisions.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"However, the landscape around Mt. Firmament is complex. One must be accompanied by a special \"Wayfinder\" to navigate safely. That's all I know.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"Currently, she's likely at the ferry terminal in Whining Aix's Mire. I'll reach out to her.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"To learn more about Mt. Firmament, you can meet her at the ferry. I lack the same level of understanding of the situation there as she does.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"I trust Madam Magistrate's decisions. I will do my utmost to handle the public matters on her behalf while she is away.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"I just... This worry about her safety won't leave me.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"In her last video message, I could tell she seemed weaker than usual, despite her efforts to maintain composure.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"Madam Magistrate's situation might not be optimistic...","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"{PlayerName}, Mt. Firmament is a dangerous place. Please take care.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"I have sent the coordinates to your Terminal. Thank you for your kind help. I pray you will both return safely.","quest_name":"Dreamweaver's Ascent","quest_id":125000120},{"text":"I regret to inform you that Madam Magistrate is currently away. Prior to her departure, she instructed me to bring you these tokens and a welcome gift.","quest_name":"First Resonance","quest_id":139000027},{"text":"Madam Magistrate advised you to explore what these tokens represent during her absence. This may help you acquire the information you desire sooner.","quest_name":"First Resonance","quest_id":139000027},{"text":"I apologize for the inconvenience, but please rest assured: she will be here to meet you in three days' time.","quest_name":"First Resonance","quest_id":139000027},{"text":"Sorry... I cannot disclose her whereabouts at this time. Please trust me that she is eagerly looking forward to meeting you in person.","quest_name":"First Resonance","quest_id":139000027},{"text":"Pardon my inability to provide a better answer. Madam Magistrate has a task that she must handle alone, but she has never for one moment forgotten about her meeting with you.","quest_name":"First Resonance","quest_id":139000027},{"text":"Not knowing exactly when you'd arrive, she had to leave without having the chance to welcome you in person.","quest_name":"First Resonance","quest_id":139000027},{"text":"Because she will require at least three days to complete her current task.","quest_name":"First Resonance","quest_id":139000027},{"text":"Madam Magistrate wanted to assure you that in three days, by any means, she will return to meet you in person.","quest_name":"First Resonance","quest_id":139000027},{"text":"You...","quest_name":"First Resonance","quest_id":139000027},{"text":"I'll be sure to convey your kindness to Madam Magistrate. Please accept my sincerest gratitude.","quest_name":"First Resonance","quest_id":139000027},{"text":"Yes, Madam Magistrate does hope to have your assistance, but there is no rush for a decision. She does not want to pressure you into anything you may not desire. We invite you to learn about our situation before making a final commitment.","quest_name":"First Resonance","quest_id":139000027},{"text":"When it comes to these tokens, it is never her intention to confuse you with the puzzles. Instead, they should serve as clues that lead you toward the truth.","quest_name":"First Resonance","quest_id":139000027},{"text":"Madam Magistrate deeply regrets not having the time to deliver her messages to you in person.","quest_name":"First Resonance","quest_id":139000027},{"text":"We value your presence far more than you might imagine. The same goes for any and all information about you.","quest_name":"First Resonance","quest_id":139000027},{"text":"Since Madam Magistrate is currently away, I cannot make the final confirmation on her behalf.","quest_name":"First Resonance","quest_id":139000027},{"text":"But you. You are truly exceptional.","quest_name":"First Resonance","quest_id":139000027},{"text":"Regarding that...","quest_name":"First Resonance","quest_id":139000027},{"text":"My eyes can see the frequencies of all living beings.","quest_name":"First Resonance","quest_id":139000027},{"text":"Or rather, those \"frequencies\" are the only thing I can see.","quest_name":"First Resonance","quest_id":139000027},{"text":"You... You share the same frequency with Madam Magistrate.","quest_name":"First Resonance","quest_id":139000027},{"text":"You look undistorted and authentic, in your original form.","quest_name":"First Resonance","quest_id":139000027},{"text":"Apologies. My description was not accurate.","quest_name":"First Resonance","quest_id":139000027},{"text":"Both you and Madam Magistrate look undistorted to me.","quest_name":"First Resonance","quest_id":139000027},{"text":"In my eyes, you appear the way you are.","quest_name":"First Resonance","quest_id":139000027},{"text":"They all look different.","quest_name":"First Resonance","quest_id":139000027},{"text":"They are unharmed. Please rest assured.","quest_name":"Ominous Star","quest_id":139000030},{"text":"As you anticipated, Scar did not try to kill them... Yes, I stayed out of it like you asked.","quest_name":"Ominous Star","quest_id":139000030},{"text":"Is everything alright on your end?","quest_name":"Ominous Star","quest_id":139000030},{"text":"...Please be sure to stay safe, My Lady.","quest_name":"Ominous Star","quest_id":139000030},{"text":"How dare you! Madam Magistrate, I...","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Watch out!","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Yes, Madam Magistrate.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Understood. Should I continue protecting that Rover?","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Is Lady Changli leaving for the capital?","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Please pardon my intrusion, but {Male=he;Female=she} just faced an ambush in the Central Plains. What if...","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Understood. I will.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"My lady... No matter what happens, my sword is always yours.","quest_name":"Clashing Blades","quest_id":139000031}]}