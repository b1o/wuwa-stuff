{"words":[{"word":"rover","count":3},{"word":"madam","count":2},{"word":"barrier","count":2},{"word":"evacuated","count":2},{"word":"informed","count":2},{"word":"yangyang","count":2},{"word":"soon","count":2},{"word":"city","count":2},{"word":"heading","count":2},{"word":"safe","count":2},{"word":"academy","count":2},{"word":"ministry","count":2},{"word":"male","count":2},{"word":"female","count":2},{"word":"almost","count":1},{"word":"identical","count":1},{"word":"saw","count":1},{"word":"three","count":1},{"word":"years","count":1},{"word":"ago","count":1},{"word":"battle","count":1},{"word":"beneath","count":1},{"word":"crescent","count":1},{"word":"afraid","count":1},{"word":"already","count":1},{"word":"running","count":1},{"word":"time","count":1},{"word":"magistrate","count":1},{"word":"fully","count":1},{"word":"repaired","count":1},{"word":"residents","count":1},{"word":"successfully","count":1},{"word":"minimized","count":1},{"word":"damage","count":1},{"word":"border","count":1},{"word":"checkpoints","count":1},{"word":"across","count":1},{"word":"jinzhou","count":1},{"word":"trip","count":1},{"word":"front","count":1},{"word":"line","count":1},{"word":"granted","count":1},{"word":"unlimited","count":1},{"word":"access","count":1},{"word":"places","count":1},{"word":"outriders","count":1},{"word":"hope","count":1},{"word":"provide","count":1},{"word":"assistance","count":1},{"word":"pass","count":1},{"word":"tacet","count":1},{"word":"field","count":1},{"word":"reach","count":1},{"word":"base","count":1},{"word":"desorock","count":1},{"word":"highland","count":1},{"word":"please","count":1},{"word":"careful","count":1},{"word":"seems","count":1},{"word":"rain","count":1},{"word":"stopping","count":1},{"word":"anytime","count":1},{"word":"hehe","count":1},{"word":"everyone's","count":1},{"word":"ready","count":1},{"word":"defend","count":1},{"word":"i've","count":1},{"word":"general","count":1},{"word":"jiyan","count":1},{"word":"place","count":1},{"word":"meeting","count":1},{"word":"magistrate's","count":1},{"word":"command","count":1},{"word":"activated","count":1},{"word":"citizens","count":1},{"word":"zone","count":1},{"word":"huaxu","count":1},{"word":"development","count":1},{"word":"standby","count":1},{"word":"instructions","count":1},{"word":"bazhi","count":1},{"word":"overseeing","count":1},{"word":"operations","count":1},{"word":"mortefi","count":1},{"word":"arrived","count":1},{"word":"rest","count":1},{"word":"assured","count":1},{"word":"meet","count":1},{"word":"coming","count":1}],"lines":[{"text":"Now it's almost identical to what we saw three years ago, during the \"Battle Beneath the Crescent\".","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"I'm afraid... We're already running out of time.","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"Madam Magistrate, the barrier has been fully repaired and we have evacuated all residents. We've successfully minimized the damage.","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"Rover, I have informed border checkpoints across Jinzhou about your trip to the front line. You have been granted unlimited access to all places.","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"Yangyang, you're one of our Outriders. I hope you can go with Rover and provide assistance.","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"You'll need to pass through a Tacet Field to reach our base in the Desorock Highland. Please be careful.","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"It seems the rain is not stopping anytime soon...","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"Hehe, as you can see. Everyone's ready to defend our city.","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"I've informed General Jiyan that you're heading to his place. He will be meeting up with you soon.","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"Under Madam Magistrate's command, the barrier has been activated and citizens are being evacuated to the safe zone.","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"Huaxu Academy and Ministry of Development are on standby for further instructions. Bazhi is overseeing operations at the Academy while Mortefi has arrived at the Ministry. Rest assured, we are all safe in the city.","quest_name":"Grand Warstorm","quest_id":140000004},{"text":"And that Rover... {Male=He;Female=She} is heading over to meet you. Yangyang is coming with {Male=him;Female=her}.","quest_name":"Grand Warstorm","quest_id":140000004}]}