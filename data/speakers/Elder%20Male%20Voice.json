{"words":[{"word":"time","count":2},{"word":"gate","count":2},{"word":"past","count":2},{"word":"future","count":2},{"word":"please","count":2},{"word":"getting","count":1},{"word":"closer","count":1},{"word":"final","count":1},{"word":"words","count":1},{"word":"haha","count":1},{"word":"thought","count":1},{"word":"enemies","count":1},{"word":"misconceptions","count":1},{"word":"waning","count":1},{"word":"passion","count":1},{"word":"ignorance","count":1},{"word":"end","count":1},{"word":"realize","count":1},{"word":"ultimate","count":1},{"word":"foe","count":1},{"word":"became","count":1},{"word":"blindsided","count":1},{"word":"fear","count":1},{"word":"death","count":1},{"word":"insatiable","count":1},{"word":"thirst","count":1},{"word":"truth","count":1},{"word":"eventually","count":1},{"word":"derailing","count":1},{"word":"research","count":1},{"word":"late","count":1},{"word":"finally","count":1},{"word":"came","count":1},{"word":"senses","count":1},{"word":"already","count":1},{"word":"walked","count":1},{"word":"into","count":1},{"word":"false","count":1},{"word":"leaving","count":1},{"word":"last","count":1},{"word":"realization","count":1},{"word":"behind","count":1},{"word":"realized","count":1},{"word":"sooner","count":1},{"word":"chance","count":1},{"word":"things","count":1},{"word":"track","count":1},{"word":"hailing","count":1},{"word":"save","count":1},{"word":"keep","count":1},{"word":"pushing","count":1},{"word":"forward","count":1},{"word":"reach","count":1},{"word":"real","count":1},{"word":"change","count":1},{"word":"world","count":1}],"lines":[{"text":"...It's getting closer. These will be my final words, haha... If only I had more time...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"I thought my enemies were misconceptions, waning passion, and my own ignorance.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Only in the end did I realize... time is my ultimate foe.","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"I became blindsided by my fear of death and insatiable thirst for truth, eventually derailing our research...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"It was too late when I finally came back to my senses... We... We had already walked into that false \"Gate\"...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Now, I'm leaving my last realization behind...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"They are our \"past\"... but they are also our \"future\"... Had I realized it sooner, there might have been a chance to get things back on track...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"The future being hailing from our past... Please save us... once again...","quest_name":"Rewinding Raindrops","quest_id":114000020},{"text":"Please, keep pushing forward... until you reach... the real Gate that can change the world...","quest_name":"Rewinding Raindrops","quest_id":114000020}]}