{"words":[{"word":"sacred","count":3},{"word":"forth","count":2},{"word":"dear","count":1},{"word":"pilgrims","count":1},{"word":"journey","count":1},{"word":"sentinel","count":1},{"word":"guide","count":1},{"word":"guided","count":1},{"word":"returning","count":1},{"word":"ships","count":1},{"word":"andreas","count":1},{"word":"fool","count":1},{"word":"benevolent","count":1},{"word":"primus","count":1},{"word":"blessed","count":1},{"word":"pilgrimage","count":1},{"word":"find","count":1},{"word":"righteous","count":1},{"word":"path","count":1},{"word":"voyage","count":1},{"word":"duty","count":1},{"word":"remains","count":1},{"word":"shepherd","count":1},{"word":"lost","count":1},{"word":"grieve","count":1},{"word":"brother","count":1},{"word":"strayed","count":1},{"word":"truth","count":1},{"word":"transgression","count":1},{"word":"absolved","count":1},{"word":"pilgrim's","count":1},{"word":"sail","count":1},{"word":"board","count":1},{"word":"humility","count":1}],"lines":[{"text":"Go forth, dear pilgrims, on your sacred journey. May the Sentinel guide you as it has guided the returning ships.","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"Go forth, Andreas... \"The Fool.\" The benevolent Primus has blessed you with this sacred pilgrimage. May you find the righteous path on your voyage.","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"Our duty remains here, to shepherd the lost. I grieve for you, my brother... for you have strayed from the truth.","quest_name":"Through the Sea Thou Break","quest_id":114000026},{"text":"Your transgression is absolved before the sacred Pilgrim's Sail. Go now, and board with humility.","quest_name":"Through the Sea Thou Break","quest_id":114000026}]}