:1},{"word":"forced","count":1},{"word":"kill","count":1},{"word":"means","count":1},{"word":"necessary","count":1},{"word":"willingly","count":1},{"word":"arrives","count":1},{"word":"confident","count":1},{"word":"sound","count":1},{"word":"threnodian's","count":1},{"word":"resurrection","count":1},{"word":"approaches","count":1},{"word":"barely","count":1},{"word":"holding","count":1},{"word":"longer","count":1},{"word":"keep","count":1},{"word":"facade","count":1},{"word":"unless","count":1},{"word":"overseer","count":1},{"word":"hahaha","count":1},{"word":"answered","count":1},{"word":"questions","count":1},{"word":"full","count":1},{"word":"honesty","count":1},{"word":"mind","count":1},{"word":"knowing","count":1},{"word":"difference","count":1},{"word":"stop","count":1},{"word":"late","count":1},{"word":"change","count":1},{"word":"course","count":1},{"word":"history","count":1},{"word":"question","count":1},{"word":"seem","count":1},{"word":"convinced","count":1},{"word":"caused","count":1},{"word":"disappearance","count":1},{"word":"curious","count":1},{"word":"closer","count":1},{"word":"i'll","count":1},{"word":"secret","count":1},{"word":"ears","count":1},{"word":"shocked","count":1},{"word":"made","count":1},{"word":"prophecy","count":1},{"word":"ago","count":1},{"word":"all-seeing","count":1},{"word":"abandons","count":1},{"word":"times","count":1},{"word":"adding","count":1},{"word":"touch","count":1},{"word":"extra","count":1},{"word":"fuel","count":1},{"word":"fire","count":1},{"word":"soon","count":1},{"word":"consume","count":1},{"word":"care","count":1},{"word":"wager","count":1},{"word":"searching","count":1},{"word":"answers","count":1},{"word":"past","count":1},{"word":"i've","count":1},{"word":"news","count":1},{"word":"black","count":1},{"word":"lambs","count":1},{"word":"chosen","count":1},{"word":"ushering","count":1},{"word":"discover","count":1},{"word":"hesitation","count":1},{"word":"fractsidus","count":1},{"word":"awaits","count":1},{"word":"arrival","count":1},{"word":"arms","count":1},{"word":"forward","count":1},{"word":"day","count":1},{"word":"anticipation","count":1},{"word":"hehehehehe","count":1},{"word":"ahahahahaha","count":1},{"word":"yawn","count":1},{"word":"person","count":1},{"word":"wait","count":1},{"word":"breaking","count":1},{"word":"mingting's","count":1},{"word":"nose","count":1},{"word":"without","count":1},{"word":"setting","count":1},{"word":"single","count":1},{"word":"alarm","count":1},{"word":"delicious","count":1},{"word":"idea","count":1},{"word":"spread","count":1},{"word":"pulled","count":1},{"word":"deeper","count":1},{"word":"mark","count":1},{"word":"left","count":1},{"word":"allowed","count":1},{"word":"frequency","count":1},{"word":"merge","count":1},{"word":"cost","count":1},{"word":"liked","count":1},{"word":"everything","count":1},{"word":"unfolded","count":1},{"word":"exactly","count":1},{"word":"scripted","count":1},{"word":"precision","count":1},{"word":"devotion","count":1},{"word":"bravo","count":1},{"word":"souls","count":1},{"word":"deserve","count":1},{"word":"born","count":1},{"word":"exists","count":1},{"word":"disorder","count":1},{"word":"winning","count":1},{"word":"move","count":1},{"word":"worse","count":1},{"word":"wilder","count":1},{"word":"out-chaos","count":1},{"word":"noble","count":1},{"word":"act","count":1},{"word":"makes","count":1},{"word":"hungrier","count":1},{"word":"stories","count":1},{"word":"treat","count":1},{"word":"screaming","count":1},{"word":"crowds","count":1},{"word":"drowning","count":1},{"word":"despair","count":1},{"word":"tearing","count":1},{"word":"seams","count":1},{"word":"collapse","count":1},{"word":"unraveling","count":1},{"word":"chefs","count":1},{"word":"kiss","count":1},{"word":"cannot","count":1},{"word":"overcome","count":1},{"word":"pain","count":1},{"word":"fall","count":1},{"word":"straight","count":1},{"word":"into","count":1},{"word":"eternity","count":1},{"word":"suffering","count":1},{"word":"chose","count":1},{"word":"work","count":1},{"word":"dear","count":1},{"word":"playwright","count":1},{"word":"speaking","count":1},{"word":"quillbearer","count":1},{"word":"toys","count":1},{"word":"hearts","count":1},{"word":"sins","count":1},{"word":"weigh","count":1},{"word":"heavy","count":1},{"word":"mine","count":1},{"word":"play","count":1},{"word":"oh","count":1},{"word":"playername","count":1},{"word":"wrong","count":1},{"word":"cruel","count":1},{"word":"extreme","count":1},{"word":"man","count":1},{"word":"sometimes","count":1},{"word":"insane","count":1},{"word":"who'd've","count":1},{"word":"thought","count":1},{"word":"someone","count":1},{"word":"stubborn","count":1},{"word":"learn","count":1},{"word":"adapt","count":1},{"word":"grand","count":1},{"word":"architect","count":1},{"word":"going","count":1},{"word":"walk","count":1},{"word":"pleases","count":1},{"word":"judge","count":1},{"word":"wound","count":1},{"word":"far","count":1},{"word":"faithful","count":1},{"word":"indulgences","count":1},{"word":"ever","count":1},{"word":"tag","count":1},{"word":"along","count":1},{"word":"add","count":1},{"word":"flourishes","count":1},{"word":"symphony","count":1}],"lines":[{"text":"Hehe, should I thank you for showing me mercy?","quest_name":"Ominous Star","quest_id":139000030},{"text":"Ugh. Didn't you promise to leave me some alone time with Rover?","quest_name":"Ominous Star","quest_id":139000030},{"text":"Ugh... Look at you, rushing in to protect your precious \"Perfect Movement\".","quest_name":"Ominous Star","quest_id":139000030},{"text":"No worries. I know all the dos and don'ts. I don't need you to tell me what to do.","quest_name":"Ominous Star","quest_id":139000030},{"text":"Rover, it seems our happy little date... must come to an end.","quest_name":"Ominous Star","quest_id":139000030},{"text":"But don't forget my sincere reminders.","quest_name":"Ominous Star","quest_id":139000030},{"text":"Let me know what you'll choose: an unexpected gift, an honest and open exchange, or a highly risky gamble...","quest_name":"Ominous Star","quest_id":139000030},{"text":"The choice is yours. I know how smart you are. You won't make a hasty decision.","quest_name":"Ominous Star","quest_id":139000030},{"text":"We'll meet again... in the not-too-distant future.","quest_name":"Ominous Star","quest_id":139000030},{"text":"What do I want to say, huh? While I'd love to tell you another story... I guess that's not what you want to hear.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Let's cut to the chase, “Madam Magistrate.” I'm getting bored already.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Sure, why not. What do you want to know?","quest_name":"Clashing Blades","quest_id":139000031},{"text":"A <ano=Oracle Engine>Sentinel</ano> such as Jué can predict and \"correct\" future events. It gets in our way of achieving our sublime vision.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"We merely wanted to topple the set future built on lies, and take control of our own destiny.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"The Threnodians... They hold the key to our ideal.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Together they will bring us the promised \"true Lament,\" and we will embrace the new world that is bound to come.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"What is the Lament? Disaster? Curse? Some kind of punishment? Ha! People only see the surface...","quest_name":"Clashing Blades","quest_id":139000031},{"text":"The Lament brings death, destruction, and countless Reverberations.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Reverberations that will be reflected, overlapped, and interwoven during the Lament... They will be our salvation, the only path to a new lifeform and a new civilization.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Our goal has always been the same... We want you. Want you to join us.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Forces battle over you, causing all this strife, and yet you remain unaware of your own worth... Are you really that naive, or are you just dense?","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Whatever. Our interest in you is not affected by such trivial matters.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Too bad. We will then be forced to kill you, by any means necessary...","quest_name":"Clashing Blades","quest_id":139000031},{"text":"But I'm sure you'll willingly come to us... When the time arrives.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Ha! How confident you sound. As the Threnodian's resurrection approaches, Jinzhou is barely holding on. How much longer do you think you can keep up this facade?","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Unless I'm not the only Overseer in Jinzhou, right? Hahaha...","quest_name":"Clashing Blades","quest_id":139000031},{"text":"I have answered all your questions with full honesty. I don't mind you knowing, because it won't make any difference.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"You can try to stop us with all you have... But it's too late to change the course of history.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Now, I have one question for you...","quest_name":"Clashing Blades","quest_id":139000031},{"text":"You seem convinced we caused the disappearance of Jué... What if I told you there was more to it? Would you be curious?","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Come closer and I'll tell you, Madam Magistrate... It's a secret for your ears only...","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Shocked, aren't you? But there's more...","quest_name":"Clashing Blades","quest_id":139000031},{"text":"What if I told you... Your Sentinel had made this prophecy a long, long time ago?","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Your all-seeing Sentinel abandons you now of all times. Need I say more?","quest_name":"Clashing Blades","quest_id":139000031},{"text":"We're merely adding a touch of extra fuel to the fire that will soon consume all.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Rover, care for a wager? I know you've been searching for answers about your past, and I've got news for you—","quest_name":"Clashing Blades","quest_id":139000031},{"text":"You are one of us, the \"black lambs,\" and you have been chosen to join us ushering in the new world...","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Once you discover what you really are, you will come to us with no hesitation.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"The Fractsidus awaits your arrival with open arms.","quest_name":"Clashing Blades","quest_id":139000031},{"text":"And I look forward to that day in sincere anticipation...","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Hehehehehe.... AHAHAHAHAHA!","quest_name":"Clashing Blades","quest_id":139000031},{"text":"Yawn... You do love to make a person wait, don't you?","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Still, breaking me out right under Mingting's nose without setting off a single alarm... Delicious. Tell me, how did you come up with that little idea?","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"As the Dark Tide spread and I was pulled in deeper, the mark of the Dark Tide you left in me allowed my frequency to merge with it...","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"It cost more time than I'd have liked, but everything unfolded exactly as you scripted. Such precision. Such devotion... Bravo.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"No souls deserve salvation. Why even try? This world was born from Chaos and exists in disorder. The only winning move... is to be worse. Wilder. To out-chaos the Chaos.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Every noble act of salvation only makes Chaos hungrier. You want to destroy to save, but me... Ha, I want to save to destroy.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Did I say that? Your stories have always been a treat. Screaming crowds drowning in despair, a world tearing at the seams... Every collapse, every unraveling... Chefs kiss.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"If they cannot overcome the pain, then let them fall straight into the ending I want: an eternity of chaos and suffering. That's why I chose to work with you, dear playwright.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Speaking of which, Quillbearer who toys with hearts, your sins weigh as heavy as mine. Tell me... where will your ending play out?","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Oh, {PlayerName} wasn't wrong about you. You really are a cruel, extreme man. Sometimes I think you might be even more insane than I am.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Huh… who'd've thought someone as stubborn as she would learn to adapt.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"But, Grand Architect, are you really going to let her walk off and do as she pleases?","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Judge? You wound me. I'm far more faithful to my indulgences than she ever was. No, no, no, no, I just want to tag along… and add a few more flourishes to her symphony.","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019}]}