{"words":[{"word":"passenger","count":3},{"word":"hello","count":1},{"word":"hm","count":1},{"word":"shame","count":1},{"word":"dessert","count":1},{"word":"ready","count":1},{"word":"suppose","count":1},{"word":"reward","count":1},{"word":"promised","count":1},{"word":"left","count":1},{"word":"care","count":1},{"word":"y'know","count":1},{"word":"first","count":1},{"word":"wandered","count":1},{"word":"put","count":1},{"word":"cheerful","count":1},{"word":"face","count":1},{"word":"feel","count":1},{"word":"weight","count":1},{"word":"little","count":1},{"word":"adventure","count":1},{"word":"together","count":1},{"word":"any","count":1},{"word":"happier","count":1},{"word":"wonderful","count":1},{"word":"making","count":1},{"word":"sure","count":1},{"word":"honami's","count":1},{"word":"people","count":1},{"word":"happy","count":1},{"word":"duties","count":1},{"word":"chisa","count":1},{"word":"i-i","count":1},{"word":"confirmed","count":1},{"word":"neon","count":1},{"word":"tower's","count":1},{"word":"coordinates","count":1}],"lines":[{"text":"Hello again, Passenger! Hm? Where's the other Passenger?","quest_name":"Whispers of the Waves","quest_id":165850000},{"text":"I see, I see. What a shame. I even had dessert ready for her. More for me, I suppose.","quest_name":"Whispers of the Waves","quest_id":165850000},{"text":"This is the reward she promised. She left it in my care for you.","quest_name":"Whispers of the Waves","quest_id":165850000},{"text":"Y'know, when she first wandered in here, she put on a cheerful face. But I could feel the weight on her.","quest_name":"Whispers of the Waves","quest_id":165850000},{"text":"On your little adventure together, did she get any happier?","quest_name":"Whispers of the Waves","quest_id":165850000},{"text":"Wonderful! After all, making sure Honami's people are happy is one of my duties, you know!","quest_name":"Whispers of the Waves","quest_id":165850000},{"text":"Chisa—! Passenger—!","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044},{"text":"I-I just confirmed Neon Tower's coordinates!","quest_name":"Stagnant Dawn on Wastelands","quest_id":880000044}]}