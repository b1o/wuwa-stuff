{"words":[{"word":"arena","count":3},{"word":"never","count":2},{"word":"i'll","count":2},{"word":"bad","count":2},{"word":"into","count":2},{"word":"wanna","count":2},{"word":"win","count":2},{"word":"better","count":2},{"word":"homeland","count":1},{"word":"septimont","count":1},{"word":"going","count":1},{"word":"mine","count":1},{"word":"victory","count":1},{"word":"raised","count":1},{"word":"understand","count":1},{"word":"viburnum","count":1},{"word":"flowers","count":1},{"word":"relax","count":1},{"word":"mya","count":1},{"word":"hold","count":1},{"word":"alright","count":1},{"word":"fine","count":1},{"word":"i've","count":1},{"word":"met","count":1},{"word":"people","count":1},{"word":"supported","count":1},{"word":"cheered","count":1},{"word":"since","count":1},{"word":"first","count":1},{"word":"stepped","count":1},{"word":"limits","count":1},{"word":"matter","count":1},{"word":"push","count":1},{"word":"far","count":1},{"word":"love","count":1},{"word":"gladiating","count":1},{"word":"stepping","count":1},{"word":"makes","count":1},{"word":"feel","count":1},{"word":"happy","count":1},{"word":"treat","count":1},{"word":"hobby","count":1},{"word":"seen","count":1},{"word":"hear","count":1},{"word":"cheer","count":1},{"word":"laughter","count":1},{"word":"cheers","count":1},{"word":"money","count":1},{"word":"oh","count":1},{"word":"divinity","count":1},{"word":"hope","count":1},{"word":"anyone","count":1}],"lines":[{"text":"You... are...","quest_name":"Flames of Heart","quest_id":121000038},{"text":"From my homeland...","quest_name":"Flames of Heart","quest_id":121000038},{"text":"Septimont...","quest_name":"Flames of Heart","quest_id":121000038},{"text":"...","quest_name":"Flames of Heart","quest_id":121000038},{"text":"...Where... are you going...?","quest_name":"Flames of Heart","quest_id":121000038},{"text":"That... was never... mine... the arena...","quest_name":"Flames of Heart","quest_id":121000038},{"text":"I... don't... need... this... victory...!","quest_name":"Flames of Heart","quest_id":121000038},{"text":"We were... raised... by... them...","quest_name":"Flames of Heart","quest_id":121000038},{"text":"You... will never... understand...","quest_name":"Flames of Heart","quest_id":121000038},{"text":"No... Viburnum... my... flowers...","quest_name":"Flames of Heart","quest_id":121000038},{"text":"Relax, Mya. You can do this... Hold on.","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"It's alright... I'll be fine...","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"It... It hasn't been all bad. I've met people who supported me. They cheered me on since I first stepped into the arena...","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"But... I know my limits.","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"No matter how much I push myself, this is as far as I'll go.","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"I love this. Gladiating. Just stepping into the arena makes me feel... happy.","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"But here... I can't treat it like a hobby.","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"And... I want to be seen! To hear them cheer for me! Their laughter, their cheers... I wanna win! I wanna win so, so bad!","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"...And I need the money.","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"...","quest_name":"Shadow of Glory","quest_id":125000126},{"text":"Oh, Divinity above, I hope I won't let anyone down. I need to be better. Much, much better...","quest_name":"Shadow of Glory","quest_id":125000126}]}