{"words":[{"word":"thought","count":1},{"word":"wiser","count":1},{"word":"dangers","count":1},{"word":"pilgrimage","count":1},{"word":"yet","count":1},{"word":"cling","count":1},{"word":"reckless","count":1},{"word":"path","count":1},{"word":"drives","count":1},{"word":"stubbornness","count":1},{"word":"hmph","count":1},{"word":"pitiful","count":1},{"word":"fool","count":1},{"word":"seas","count":1},{"word":"reverberation","count":1},{"word":"believe","count":1},{"word":"dearly","count":1}],"lines":[{"text":"And here I thought you'd be much wiser than this.","quest_name":"Your Summer Will Never Wither","quest_id":165000003},{"text":"You know the dangers of pilgrimage, yet you all still cling to the same reckless path. Tell me, what drives such stubbornness?","quest_name":"Your Summer Will Never Wither","quest_id":165000003},{"text":"And? What of it?","quest_name":"Your Summer Will Never Wither","quest_id":165000003},{"text":"Hmph. You pitiful fool. Off to the seas with that \"Reverberation\" you believe in so dearly.","quest_name":"Your Summer Will Never Wither","quest_id":165000003}]}