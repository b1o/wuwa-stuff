{"words":[{"word":"time","count":2},{"word":"every","count":2},{"word":"raid","count":2},{"word":"knows","count":1},{"word":"appeared","count":1},{"word":"vanished","count":1},{"word":"hunted","count":1},{"word":"slipped","count":1},{"word":"noose","count":1},{"word":"immortal","count":1},{"word":"raging","count":1},{"word":"storm","count":1},{"word":"crashing","count":1},{"word":"wave","count":1},{"word":"sharpest","count":1},{"word":"blade","count":1},{"word":"kill","count":1},{"word":"strong","count":1},{"word":"hell","count":1},{"word":"guts","count":1},{"word":"pilgrim's","count":1},{"word":"sails","count":1},{"word":"anyway","count":1},{"word":"always","count":1},{"word":"ruined","count":1},{"word":"plans","count":1},{"word":"set","count":1},{"word":"merchant","count":1},{"word":"ships","count":1},{"word":"fiery","count":1},{"word":"bastard","count":1},{"word":"swoop","count":1},{"word":"flames","count":1},{"word":"blazing","count":1}],"lines":[{"text":"No one knows when he appeared","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Or when he vanished…","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"He was hunted time and again","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"But slipped through every noose","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"They say he's immortal, for no raging storm—","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Nor crashing wave","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Not even the sharpest blade can kill him!","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Strong as hell, that one was","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Had the guts to raid the Pilgrim's Sails again and again","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Anyway","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"He always ruined our plans!","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Every time we set off to raid those merchant ships","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"This fiery bastard would swoop in, flames blazing!","quest_name":"Sail Day, Captain!","quest_id":155000000}]}