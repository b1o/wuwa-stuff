{"words":[{"word":"wonderful","count":1},{"word":"performance","count":1},{"word":"take","count":1},{"word":"care","count":1},{"word":"overindulge","count":1},{"word":"offer","count":1},{"word":"home","count":1},{"word":"delivery","count":1},{"word":"humans","count":1},{"word":"assure","count":1},{"word":"despicable","count":1},{"word":"done","count":1},{"word":"customers","count":1},{"word":"show","count":1},{"word":"remorse","count":1},{"word":"order","count":1},{"word":"tribunal","count":1},{"word":"judgment","count":1},{"word":"away","count":1},{"word":"helped","count":1},{"word":"rinascita","count":1},{"word":"darkest","count":1},{"word":"hour","count":1},{"word":"turn","count":1},{"word":"sure","count":1},{"word":"heroes","count":1},{"word":"eat","count":1},{"word":"drink","count":1},{"word":"royalty","count":1},{"word":"double","count":1},{"word":"scoop","count":1},{"word":"house","count":1},{"word":"unlimited","count":1},{"word":"refills","count":1},{"word":"ms","count":1},{"word":"ciaccona","count":1},{"word":"hmm","count":1},{"word":"squirreling","count":1},{"word":"towards","count":1},{"word":"harbor","count":1},{"word":"earlier","count":1},{"word":"thought","count":1},{"word":"meeting","count":1},{"word":"word","count":1},{"word":"quite","count":1},{"word":"though","count":1},{"word":"never","count":1},{"word":"seen","count":1},{"word":"wear","count":1},{"word":"gloomy","count":1},{"word":"face","count":1}],"lines":[{"text":"That was a wonderful performance!","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Take care not to overindulge again. We don't offer home delivery for humans, I assure you.","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Despicable! After all you've done to our customers, you show no remorse. You're off to the Order Tribunal for judgment!","quest_name":"Sail Day, Captain!","quest_id":155000000},{"text":"Right away! You helped Rinascita through its darkest hour. Now it's my turn to make sure our heroes eat and drink like royalty!","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Here you go! Double the scoop, on the house! Unlimited refills!","quest_name":"Dawn Breaks on Dark Tides","quest_id":158800019},{"text":"Ms. Ciaccona... Hmm, she was squirreling off towards the harbor earlier. I thought that's where you were meeting, so I didn't say a word.","quest_name":"Your Summer Will Never Wither","quest_id":165000003},{"text":"She did look quite down, though. Never seen her wear such a gloomy face before.","quest_name":"Your Summer Will Never Wither","quest_id":165000003}]}