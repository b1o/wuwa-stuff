{"words":[{"word":"playername","count":5},{"word":"matrix","count":5},{"word":"stellar","count":4},{"word":"color","count":4},{"word":"error","count":3},{"word":"cell","count":3},{"word":"shorekeeper","count":3},{"word":"i'll","count":3},{"word":"reach","count":3},{"word":"remember","count":2},{"word":"worry","count":2},{"word":"great","count":2},{"word":"black","count":2},{"word":"shores","count":2},{"word":"escaped","count":2},{"word":"deeper","count":2},{"word":"modulation","count":2},{"word":"any","count":2},{"word":"data","count":2},{"word":"camellya","count":2},{"word":"inside","count":2},{"word":"areas","count":2},{"word":"destination","count":2},{"word":"highlight","count":2},{"word":"please","count":2},{"word":"hey","count":1},{"word":"beatrice","count":1},{"word":"hate","count":1},{"word":"ask","count":1},{"word":"run","count":1},{"word":"into","count":1},{"word":"trouble","count":1},{"word":"honestly","count":1},{"word":"trusts","count":1},{"word":"handle","count":1},{"word":"explain","count":1},{"word":"everything","count":1},{"word":"thanks","count":1},{"word":"lot","count":1},{"word":"reward","count":1},{"word":"since","count":1},{"word":"came","count":1},{"word":"many","count":1},{"word":"unexpected","count":1},{"word":"things","count":1},{"word":"happened","count":1},{"word":"made","count":1},{"word":"appearance","count":1},{"word":"anyway","count":1},{"word":"point","count":1},{"word":"memory","count":1},{"word":"sharp","count":1},{"word":"ever","count":1},{"word":"basically","count":1},{"word":"prison","count":1},{"word":"containing","count":1},{"word":"hazardous","count":1},{"word":"waste","count":1},{"word":"corrupted","count":1},{"word":"matrices","count":1},{"word":"problem","count":1},{"word":"prisoners","count":1},{"word":"headed","count":1},{"word":"towards","count":1},{"word":"necrostar","count":1},{"word":"seems","count":1},{"word":"trying","count":1},{"word":"tied","count":1},{"word":"leave","count":1},{"word":"help","count":1},{"word":"recapture","count":1},{"word":"prevent","count":1},{"word":"incidents","count":1},{"word":"best","count":1},{"word":"person","count":1},{"word":"job","count":1},{"word":"worth","count":1},{"word":"time","count":1},{"word":"escapee","count":1},{"word":"hiding","count":1},{"word":"use","count":1},{"word":"remnants","count":1},{"word":"track","count":1},{"word":"matter","count":1},{"word":"investigating","count":1},{"word":"discovered","count":1},{"word":"years","count":1},{"word":"ago","count":1},{"word":"consultant","count":1},{"word":"accessed","count":1},{"word":"field","count":1},{"word":"recently","count":1},{"word":"returned","count":1},{"word":"check","count":1},{"word":"first","count":1},{"word":"thank","count":1},{"word":"counting","count":1},{"word":"sorry","count":1},{"word":"cunning","count":1},{"word":"anticipated","count":1},{"word":"mistake","count":1},{"word":"trapped","count":1},{"word":"started","count":1},{"word":"sink","count":1},{"word":"besides","count":1},{"word":"found","count":1},{"word":"core","count":1},{"word":"without","count":1},{"word":"create","count":1},{"word":"symmetrical","count":1},{"word":"allow","count":1},{"word":"previously","count":1},{"word":"inaccessible","count":1},{"word":"various","count":1},{"word":"simulated","count":1},{"word":"find","count":1},{"word":"jump","count":1},{"word":"correct","count":1},{"word":"timeline","count":1},{"word":"junctures","count":1},{"word":"due","count":1},{"word":"mutated","count":1},{"word":"multiple","count":1},{"word":"jumps","count":1},{"word":"required","count":1},{"word":"stay","count":1},{"word":"safe","count":1},{"word":"impressive","count":1},{"word":"fast","count":1},{"word":"head","count":1},{"word":"hall","count":1},{"word":"meet","count":1}],"lines":[{"text":"Hey, {PlayerName}. It's Beatrice. Remember me from the Error Cell?","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"I hate to ask, but could you come back to the Error Cell?","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"We've run into some trouble, and honestly, you're the only one the Shorekeeper trusts to handle it.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"I'll explain everything when you get here.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Thanks a lot! And don't worry, there'll be a reward for you.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"{PlayerName}, there you are! It's been a while, and you still look great.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Since you came to the Black Shores, so many unexpected things have happened… Even the Shorekeeper made an appearance.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Anyway, let's get to the point. Do you remember what the Error Cell is for?","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Great, your memory is as sharp as ever.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Well, it's basically a \"prison\" for containing hazardous waste like corrupted Stellar Matrices.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"The problem is, one of the \"prisoners\" has escaped.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"It's headed towards the Necrostar and seems to be trying to go even deeper.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"The Shorekeeper is tied up with modulation and can't leave.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"That's why I need your help to recapture it and prevent any more incidents. You're the best person for the job.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Don't worry, I'll make it worth your time.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"The escapee is hiding, but we can use the remnants of its data to track it down.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"What's the matter?","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"While investigating, I discovered that a few years ago, a Consultant accessed these data.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"She was out in the field recently and just returned to the Black Shores. You should check in with her first.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Thank you. I'm counting on you!","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"{PlayerName}, I'm sorry. That matrix is more cunning than we anticipated… My mistake.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Camellya is still inside that Stellar Matrix.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"She was trapped inside and started to sink deeper—that's why you couldn't go any further.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Besides, Camellya has found the matrix core. Without her, it might have escaped again.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Now, we'll create a symmetrical Stellar Matrix, and that will allow you to reach the previously inaccessible areas.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"There will be various simulated areas. To reach the destination, you need to <color=Highlight>find and jump to the correct timeline junctures</color>.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Due to a mutated Stellar Matrix, you may not reach the destination in one go.","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"<color=Highlight>Multiple jumps</color> might be required to get there. {PlayerName}, please stay safe!","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"How impressive, {PlayerName}! That's fast!","quest_name":"Forking Paths Among the Stars","quest_id":886000000},{"text":"Please head to the Modulation Hall. I'll meet you there.","quest_name":"Forking Paths Among the Stars","quest_id":886000000}]}