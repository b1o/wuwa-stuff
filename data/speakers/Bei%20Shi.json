{"words":[{"word":"bell","count":9},{"word":"brother","count":8},{"word":"jingle","count":6},{"word":"beast","count":6},{"word":"never","count":5},{"word":"please","count":5},{"word":"big","count":4},{"word":"anything","count":4},{"word":"really","count":4},{"word":"ringing","count":4},{"word":"heard","count":4},{"word":"must","count":4},{"word":"pioneer","count":3},{"word":"association","count":3},{"word":"playername","count":3},{"word":"hear","count":3},{"word":"away","count":3},{"word":"yes","count":3},{"word":"sound","count":3},{"word":"working","count":3},{"word":"looking","count":2},{"word":"made","count":2},{"word":"bei","count":2},{"word":"ji","count":2},{"word":"fight","count":2},{"word":"left","count":2},{"word":"packages","count":2},{"word":"time","count":2},{"word":"help","count":2},{"word":"thank","count":2},{"word":"always","count":2},{"word":"probably","count":2},{"word":"brother's","count":2},{"word":"run","count":2},{"word":"danger","count":2},{"word":"wilderness","count":2},{"word":"chasing","count":2},{"word":"told","count":2},{"word":"message","count":2},{"word":"kept","count":2},{"word":"alright","count":2},{"word":"lingyang","count":2},{"word":"sorry","count":1},{"word":"any","count":1},{"word":"liondancing","count":1},{"word":"requests","count":1},{"word":"nothing","count":1},{"word":"else","count":1},{"word":"excuse","count":1},{"word":"week","count":1},{"word":"home","count":1},{"word":"stopped","count":1},{"word":"talking","count":1},{"word":"last","count":1},{"word":"house","count":1},{"word":"sends","count":1},{"word":"bunch","count":1},{"word":"strange","count":1},{"word":"stuff","count":1},{"word":"mentioned","count":1},{"word":"hanging","count":1},{"word":"people","count":1},{"word":"savages","count":1},{"word":"letters","count":1},{"word":"anyone","count":1},{"word":"worried","count":1},{"word":"trouble","count":1},{"word":"reported","count":1},{"word":"police","count":1},{"word":"handle","count":1},{"word":"used","count":1},{"word":"member","count":1},{"word":"pioneers","count":1},{"word":"challenge","count":1},{"word":"ask","count":1},{"word":"amazing","count":1},{"word":"guy","count":1},{"word":"brings","count":1},{"word":"dude","count":1},{"word":"works","count":1},{"word":"oh","count":1},{"word":"useful","count":1},{"word":"b-but","count":1},{"word":"many","count":1},{"word":"campsites","count":1},{"word":"wild","count":1},{"word":"pinpoint","count":1},{"word":"exact","count":1},{"word":"location","count":1},{"word":"couple","count":1},{"word":"words","count":1},{"word":"phew","count":1},{"word":"gone","count":1},{"word":"sure","count":1},{"word":"hiding","count":1},{"word":"i-i'm","count":1},{"word":"going","count":1},{"word":"find","count":1},{"word":"soon","count":1},{"word":"possible","count":1},{"word":"anymore","count":1},{"word":"stay","count":1},{"word":"safe","count":1},{"word":"two","count":1},{"word":"true","count":1},{"word":"love","count":1},{"word":"promise","count":1},{"word":"stupid","count":1},{"word":"loud","count":1},{"word":"clear","count":1},{"word":"mistaken","count":1},{"word":"chased","count":1},{"word":"creature","count":1},{"word":"thought","count":1},{"word":"figured","count":1},{"word":"attacked","count":1},{"word":"saw","count":1},{"word":"perform","count":1},{"word":"today","count":1},{"word":"came","count":1},{"word":"saved","count":1},{"word":"sounded","count":1},{"word":"actually","count":1},{"word":"guiding","count":1},{"word":"yeah","count":1},{"word":"loved","count":1},{"word":"performance","count":1},{"word":"keep","count":1},{"word":"explorer","count":1},{"word":"upset","count":1},{"word":"carried","count":1},{"word":"burden","count":1},{"word":"alone","count":1},{"word":"gonna","count":1},{"word":"kill","count":1},{"word":"ever","count":1},{"word":"something","count":1},{"word":"thing","count":1},{"word":"hmm","count":1},{"word":"ah","count":1},{"word":"i-it's","count":1},{"word":"joined","count":1},{"word":"decision","count":1},{"word":"childhood","count":1},{"word":"dream","count":1},{"word":"eek","count":1},{"word":"ago","count":1},{"word":"mission","count":1},{"word":"ambushed","count":1},{"word":"tacet","count":1},{"word":"discords","count":1},{"word":"struggled","count":1},{"word":"escape","count":1},{"word":"distance","count":1},{"word":"i-i","count":1},{"word":"remember","count":1},{"word":"scared","count":1},{"word":"mind","count":1},{"word":"went","count":1},{"word":"completely","count":1},{"word":"blank","count":1},{"word":"hearing","count":1},{"word":"running","count":1},{"word":"without","count":1},{"word":"disappeared","count":1},{"word":"reached","count":1},{"word":"safer","count":1},{"word":"place","count":1},{"word":"perhaps","count":1},{"word":"eaten","count":1},{"word":"l-let's","count":1},{"word":"device","count":1},{"word":"bad","count":1},{"word":"guys","count":1},{"word":"shy","count":1},{"word":"careful","count":1},{"word":"sneaky","count":1},{"word":"timid","count":1},{"word":"loves","count":1},{"word":"rover","count":1}],"lines":[{"text":"Sorry, but I'm not the one you're looking for. I never made any liondancing requests...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"...No, it can't be. Now, if there's nothing else, please excuse me.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"How did you know...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"...It's about my brother, Bei Ji. It's been a week now, and he still hasn't come back home.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"My brother and I stopped talking to each other a while back, after a big fight. I don't even know when he last left our house...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"But... he still sends me packages from time to time. It's been a bunch of strange stuff...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"He mentioned hanging out with people from The Savages in one of his letters...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I didn't tell anyone, because I was worried my brother would get in trouble if I reported it to the police.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Can I go with you?","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I... I can handle it. I used to be a member of the Pioneer Association, too.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Us Pioneers never... never back down from a challenge...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"But... I...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"{PlayerName}, I know it's a big ask...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"But please... Please help me!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Amazing! Thank you, {PlayerName}!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"The guy who brings my packages is always the same dude, and I know where he works.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Oh well... We didn't get anything useful from him...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"B-but there are so many campsites in the wild, how can we pinpoint its exact location with a couple words from him?","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"So they're really here...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Phew... Are they gone?","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I'm sure I did hear the bell ringing... So the Jingle Beast is probably hiding in here, too!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I-I'm going with you!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"My brother's in there. I want to find him as soon as possible...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"But... I don't want to run away from danger anymore...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"...Yes, I will. Please help him!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"And please stay safe, you two!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"No... That's not true...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Yes! I love you, brother. But promise me you won't do anything stupid again.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"But I did hear the bell...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"No way! I heard it loud and clear. I couldn't have mistaken it.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I was once chased by a big creature in the wilderness. All I could hear was a bell ringing and my only thought was to run away.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Then I heard about the Jingle Beast, so I figured it must have been what attacked me.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"But when I saw you perform today, it all came back to me! That's the same bell ringing sound I had heard back then!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"So... I must have been saved by that bell.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"The bell that sounded like it was chasing after me... It was actually guiding me away from danger.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Yeah! I loved your performance! I think I can keep working as Explorer for the Pioneer Association now!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I am upset, because you never told me anything... You always carried the burden alone.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Didn't even tell me you were gonna go kill the Jingle Beast... Don't you ever do something like that again!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"This thing may still be working.  My brother could have left me a message...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Hmm... Ah! There is a message!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I-It's my brother...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"It's probably because I joined the Pioneer Association.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"My brother was really against my decision...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"But that was my childhood dream, so we had a big fight...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I... I don't know. He never told me anything about it...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Eek!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"No... It must be the Jingle Beast!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I know... I know that sound too well.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"A while ago, when I was on a mission in the wilderness, I got ambushed by Tacet Discords...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"As I struggled to escape, I heard the sound of a bell ringing in the distance...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I-I can't remember... I was so scared, my mind went completely blank.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"After hearing the bell, I...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"I just kept running without looking back. That bell kept chasing me and only disappeared when I reached a safer place.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"If I hadn't made it, perhaps I would have been eaten by the Jingle Beast...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"So... Yes, this must be the Jingle Beast again!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Alright... L-Let's go...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"This is... This is my brother's device.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"How could this be... Is my brother really working for those bad guys?","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"He's shy and careful, but not sneaky. He may be timid, but he really loves me...","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"...Thank you. I see.","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Lingyang! Rover!","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Lingyang! {PlayerName}! Are you alright?","quest_name":"Wild Heart's Return","quest_id":121000031},{"text":"Bei Ji!","quest_name":"Wild Heart's Return","quest_id":121000031}]}