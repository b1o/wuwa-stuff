{"words":[{"word":"wait","count":4},{"word":"people","count":2},{"word":"black","count":1},{"word":"alley's","count":1},{"word":"entrance","count":1},{"word":"value","count":1},{"word":"point","count":1},{"word":"resisting","count":1},{"word":"longer","count":1},{"word":"hold","count":1},{"word":"pain","count":1},{"word":"asking","count":1},{"word":"smart","count":1},{"word":"give","count":1},{"word":"stayed","count":1},{"word":"alive","count":1}],"lines":[{"text":"Wait, wait! Wait, wait! You're after the Black Alley's entrance, aren't you?","quest_name":"A Blaze in the Dark","quest_id":158800014},{"text":"I know my value to people.","quest_name":"A Blaze in the Dark","quest_id":158800014},{"text":"Now that you've got me, no point in resisting. The longer I hold out, the more pain I'm asking for.","quest_name":"A Blaze in the Dark","quest_id":158800014},{"text":"Smart people know when to give in. It's how I stayed alive.","quest_name":"A Blaze in the Dark","quest_id":158800014}]}